#!/bin/bash
# RSSHub service wrapper — manages Docker container for RSS feed generation.
# Called by LaunchAgent. Reads auth tokens from Keychain.

set -euo pipefail

CONTAINER_NAME="aos-rsshub"
IMAGE="diygod/rsshub:latest"
PORT=1200
LOG_DIR="$HOME/.aos/logs"
AGENT_SECRET="$HOME/aos/core/bin/cli/agent-secret"

mkdir -p "$LOG_DIR"

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') [rsshub] $*"; }

# Check Docker is available
if ! command -v docker &>/dev/null; then
    log "ERROR: Docker not installed. RSSHub requires Docker."
    log "Install Docker Desktop or colima: brew install colima && colima start"
    exit 1
fi

# Check Docker daemon is running
if ! docker info &>/dev/null 2>&1; then
    log "ERROR: Docker daemon not running. Start Docker Desktop or colima."
    exit 1
fi

# Read optional Twitter auth token from Keychain
TWITTER_AUTH_TOKEN=""
if [ -x "$AGENT_SECRET" ]; then
    TWITTER_AUTH_TOKEN=$("$AGENT_SECRET" get TWITTER_AUTH_TOKEN 2>/dev/null || echo "")
fi

# Build env args
ENV_ARGS="-e CACHE_TYPE=memory -e CACHE_EXPIRE=600"
if [ -n "$TWITTER_AUTH_TOKEN" ]; then
    ENV_ARGS="$ENV_ARGS -e TWITTER_AUTH_TOKEN=$TWITTER_AUTH_TOKEN"
    log "Twitter auth configured"
else
    log "No TWITTER_AUTH_TOKEN — Twitter routes will not work"
fi

# Check if container exists
if docker ps -a --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
    # Container exists — start it if stopped
    if docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
        log "Container already running"
    else
        log "Starting existing container..."
        docker start "$CONTAINER_NAME"
    fi
else
    # Create and start new container
    log "Creating container from $IMAGE..."
    docker pull "$IMAGE" 2>&1 | tail -1
    docker run -d \
        --name "$CONTAINER_NAME" \
        --restart unless-stopped \
        -p "${PORT}:1200" \
        --memory=256m \
        $ENV_ARGS \
        "$IMAGE"
    log "Container created and started on port $PORT"
fi

# Health check
for i in $(seq 1 15); do
    if curl -sf "http://localhost:${PORT}/healthz" &>/dev/null; then
        log "Healthy on port $PORT"
        exit 0
    fi
    sleep 2
done

log "WARNING: Not healthy after 30s — check 'docker logs $CONTAINER_NAME'"
exit 1
