#!/usr/bin/env bash
# release-manager — immutable versioned releases for AOS
#
# Architecture:
#   Git clone lives at ONE of (checked in order):
#     1. ~/project/aos/   (dev machines with AOS-X)
#     2. ~/.aos/repo/     (fleet machines, created during conversion)
#   ~/aos-releases/       Versioned release directories (read-only)
#   ~/aos                 Symlink → ~/aos-releases/<active version>/
#
# Each release is an immutable snapshot extracted from origin/main.
# Releases are chmod a-w after creation. The symlink switch is atomic.
#
# Usage:
#   release-manager create              Create release from origin/main
#   release-manager activate <version>  Switch ~/aos to a release
#   release-manager rollback            Switch to the previous release
#   release-manager list                Show all releases
#   release-manager prune [keep]        Keep last N releases (default 5)
#   release-manager current             Show active release version
#   release-manager convert             Convert git-clone ~/aos/ to release system

set -euo pipefail

RELEASES_DIR="$HOME/aos-releases"
AOS_LINK="$HOME/aos"
STATE_DIR="$HOME/.aos/data"
LOCK_FILE="$STATE_DIR/deploy.lock"
HASH_FILE="$STATE_DIR/deployed-hash"
PREV_FILE="$STATE_DIR/previous-release"

# Find the git repo — prefer ~/project/aos/ (dev), fall back to ~/.aos/repo/ (fleet)
_find_repo() {
    if [ -d "$HOME/project/aos/.git" ]; then
        echo "$HOME/project/aos"
    elif [ -d "$HOME/.aos/repo/.git" ]; then
        echo "$HOME/.aos/repo"
    else
        echo ""
    fi
}

DEV_REPO="$(_find_repo)"

mkdir -p "$RELEASES_DIR" "$STATE_DIR"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"; }

# ── Lock management ────────────────────────────────────────────────────────

acquire_lock() {
    if [ -f "$LOCK_FILE" ]; then
        local pid
        pid=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            log "ERROR: Deploy already in progress (PID $pid)"
            exit 1
        fi
        log "WARN: Stale lock from PID $pid — removing"
        rm -f "$LOCK_FILE"
    fi
    echo $$ > "$LOCK_FILE"
}

release_lock() {
    rm -f "$LOCK_FILE"
}

trap release_lock EXIT

# ── Create a new release ───────────────────────────────────────────────────

create() {
    if [ ! -d "$DEV_REPO/.git" ]; then
        log "ERROR: Dev repo not found at $DEV_REPO"
        exit 1
    fi

    log "Fetching origin/main..."
    cd "$DEV_REPO"
    git fetch origin main --quiet 2>/dev/null || {
        log "ERROR: git fetch failed (network?)"
        exit 1
    }

    local remote_hash
    remote_hash=$(git rev-parse origin/main 2>/dev/null)

    # Check if already deployed
    local deployed_hash
    deployed_hash=$(cat "$HASH_FILE" 2>/dev/null || echo "none")
    if [ "$remote_hash" = "$deployed_hash" ]; then
        log "Already at $remote_hash — no new release needed"
        return 0
    fi

    # Determine version from VERSION file at origin/main
    local version
    version=$(git show origin/main:VERSION 2>/dev/null || echo "unknown")
    local release_name
    release_name="${version}-$(echo "$remote_hash" | head -c 7)"
    local release_dir="$RELEASES_DIR/$release_name"

    if [ -d "$release_dir" ]; then
        log "Release $release_name already exists"
        echo "$release_name"
        return 0
    fi

    log "Creating release $release_name..."
    acquire_lock

    # Extract origin/main into a new release directory
    local tmpdir
    tmpdir=$(mktemp -d)
    cd "$DEV_REPO"
    git archive origin/main | tar -xf - -C "$tmpdir"

    # Move to releases dir
    mv "$tmpdir" "$release_dir"

    # Make read-only
    chmod -R a-w "$release_dir"

    log "Release $release_name created ($(du -sh "$release_dir" | cut -f1))"
    echo "$release_name"
}

# ── Activate a release ─────────────────────────────────────────────────────

activate() {
    local target="${1:-}"
    if [ -z "$target" ]; then
        log "ERROR: No version specified"
        echo "Usage: release-manager activate <version>"
        exit 1
    fi

    local release_dir="$RELEASES_DIR/$target"
    if [ ! -d "$release_dir" ]; then
        log "ERROR: Release $target not found"
        exit 1
    fi

    # Run self-test against the NEW release before switching
    log "Validating release $target..."
    local test_errors=0

    # Minimal validation — can Python scripts parse? Do critical files exist?
    if [ ! -f "$release_dir/VERSION" ]; then
        log "ERROR: Release missing VERSION file"
        test_errors=1
    fi
    if [ ! -f "$release_dir/core/bin/cli/aos" ]; then
        log "ERROR: Release missing aos CLI"
        test_errors=1
    fi
    if [ ! -d "$release_dir/core" ]; then
        log "ERROR: Release missing core/"
        test_errors=1
    fi

    # Check Python scripts parse in the new release
    local parse_fail=0
    for script in "$release_dir"/core/bin/cli/* "$release_dir"/core/bin/crons/* "$release_dir"/core/bin/internal/*; do
        [ -f "$script" ] || continue
        if head -1 "$script" 2>/dev/null | grep -q python; then
            if ! python3 -c "import py_compile; py_compile.compile('$script', doraise=True)" 2>/dev/null; then
                log "WARN: Script $(basename "$script") fails to parse"
                ((parse_fail++))
            fi
        fi
    done
    if [ "$parse_fail" -gt 0 ]; then
        log "WARN: $parse_fail Python script(s) have parse errors"
    fi

    if [ "$test_errors" -gt 0 ]; then
        log "ERROR: Validation failed — not activating $target"
        release_lock
        return 1
    fi

    # Record the current release for rollback
    if [ -L "$AOS_LINK" ]; then
        local current
        current=$(basename "$(readlink "$AOS_LINK")")
        echo "$current" > "$PREV_FILE"
    fi

    # Atomic symlink switch
    local tmp_link="${AOS_LINK}.new.$$"
    ln -sfn "$release_dir" "$tmp_link"
    mv -f "$tmp_link" "$AOS_LINK"

    # Record deployed hash
    local version_hash
    cd "$DEV_REPO"
    version_hash=$(git rev-parse origin/main 2>/dev/null || echo "unknown")
    echo "$version_hash" > "$HASH_FILE"

    log "Activated: $target"
    log "  ~/aos → $release_dir"
}

# ── Rollback ───────────────────────────────────────────────────────────────

rollback() {
    if [ ! -f "$PREV_FILE" ]; then
        log "ERROR: No previous release recorded — cannot rollback"
        exit 1
    fi

    local prev
    prev=$(cat "$PREV_FILE")
    local prev_dir="$RELEASES_DIR/$prev"

    if [ ! -d "$prev_dir" ]; then
        log "ERROR: Previous release $prev no longer exists"
        exit 1
    fi

    log "Rolling back to $prev..."

    # Record current as the new "previous" (so you can roll forward)
    if [ -L "$AOS_LINK" ]; then
        local current
        current=$(basename "$(readlink "$AOS_LINK")")
        echo "$current" > "$PREV_FILE"
    fi

    # Atomic switch
    local tmp_link="${AOS_LINK}.new.$$"
    ln -sfn "$prev_dir" "$tmp_link"
    mv -f "$tmp_link" "$AOS_LINK"

    log "Rolled back: ~/aos → $prev_dir"
}

# ── List releases ──────────────────────────────────────────────────────────

list_releases() {
    local current_target=""
    if [ -L "$AOS_LINK" ]; then
        current_target=$(basename "$(readlink "$AOS_LINK")")
    fi

    echo "Releases:"
    for dir in "$RELEASES_DIR"/*/; do
        [ -d "$dir" ] || continue
        local name
        name=$(basename "$dir")
        local size
        size=$(du -sh "$dir" 2>/dev/null | cut -f1)
        local created
        created=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M" "$dir" 2>/dev/null || stat --format="%y" "$dir" 2>/dev/null | cut -d' ' -f1,2 | cut -d'.' -f1)

        if [ "$name" = "$current_target" ]; then
            echo "  → $name  ($size, $created)  [ACTIVE]"
        else
            echo "    $name  ($size, $created)"
        fi
    done
}

# ── Prune old releases ─────────────────────────────────────────────────────

prune() {
    local keep="${1:-5}"
    local current_target=""
    if [ -L "$AOS_LINK" ]; then
        current_target=$(basename "$(readlink "$AOS_LINK")")
    fi
    local prev_target=""
    if [ -f "$PREV_FILE" ]; then
        prev_target=$(cat "$PREV_FILE")
    fi

    # Sort releases by creation time, oldest first
    local releases=()
    while IFS= read -r dir; do
        [ -d "$dir" ] || continue
        releases+=("$(basename "$dir")")
    done < <(ls -dt "$RELEASES_DIR"/*/ 2>/dev/null | tail -r)

    local total=${#releases[@]}
    if [ "$total" -le "$keep" ]; then
        log "Only $total release(s), keeping all (threshold: $keep)"
        return 0
    fi

    local to_prune=$((total - keep))
    local pruned=0
    for name in "${releases[@]}"; do
        [ "$pruned" -ge "$to_prune" ] && break
        # Never prune active or previous
        [ "$name" = "$current_target" ] && continue
        [ "$name" = "$prev_target" ] && continue

        log "Pruning $name..."
        chmod -R u+w "$RELEASES_DIR/$name" 2>/dev/null || true
        rm -rf "${RELEASES_DIR:?}/$name"
        ((pruned++))
    done

    log "Pruned $pruned release(s), $((total - pruned)) remaining"
}

# ── Current release ────────────────────────────────────────────────────────

current() {
    if [ -L "$AOS_LINK" ]; then
        local target
        target=$(readlink "$AOS_LINK")
        echo "$(basename "$target")"
    else
        echo "NOT A SYMLINK — ~/aos is a direct directory"
        exit 1
    fi
}

# ── Convert from git clone to release system ──────────────────────────────
#
# Safe one-time migration. Moves ~/aos/ (git clone) to ~/.aos/repo/ or
# preserves ~/project/aos/ if it exists. Creates first release from current
# state. Replaces ~/aos/ with a symlink. Full backup at ~/aos-backup/.
#
# If any step fails, the backup is restored automatically.

convert() {
    log "Converting to release system..."

    # Already converted?
    if [ -L "$AOS_LINK" ]; then
        log "Already converted — ~/aos is a symlink"
        return 0
    fi

    # Must be a git clone
    if [ ! -d "$AOS_LINK/.git" ]; then
        log "ERROR: ~/aos exists but is not a git clone — cannot convert"
        exit 1
    fi

    acquire_lock

    # Step 1: Ensure we're on latest main
    log "Step 1/6: Pulling latest code..."
    cd "$AOS_LINK"
    git checkout -- . 2>/dev/null || true
    git pull --ff-only origin main 2>/dev/null || {
        log "ERROR: git pull failed — aborting conversion"
        release_lock
        exit 1
    }

    local current_hash
    current_hash=$(git rev-parse HEAD 2>/dev/null)
    local version
    version=$(cat "$AOS_LINK/VERSION" 2>/dev/null || echo "unknown")
    local release_name
    release_name="${version}-$(echo "$current_hash" | head -c 7)"

    # Step 2: Determine where the git clone should live
    log "Step 2/6: Setting up git repo location..."
    local repo_dest
    if [ -d "$HOME/project/aos/.git" ]; then
        repo_dest="$HOME/project/aos"
        log "  Dev workspace exists at $repo_dest — will use it"
        # Make sure dev repo has latest main
        cd "$repo_dest"
        git fetch origin main --quiet 2>/dev/null || true
    else
        repo_dest="$HOME/.aos/repo"
        log "  Fleet machine — will move clone to $repo_dest"
    fi

    # Step 3: Create backup
    log "Step 3/6: Backing up ~/aos/ → ~/aos-backup/..."
    if [ -d "$HOME/aos-backup" ]; then
        log "  Previous backup exists — removing it"
        rm -rf "$HOME/aos-backup"
    fi
    cp -a "$AOS_LINK" "$HOME/aos-backup"

    # Step 4: Create first release from current state
    log "Step 4/6: Creating release $release_name..."
    mkdir -p "$RELEASES_DIR"
    local release_dir="$RELEASES_DIR/$release_name"

    cd "$AOS_LINK"
    git archive HEAD | tar -xf - -C "$(mktemp -d)"  # test archive works
    local tmpdir
    tmpdir=$(mktemp -d)
    git archive HEAD | tar -xf - -C "$tmpdir"
    mv "$tmpdir" "$release_dir"
    chmod -R a-w "$release_dir"

    # Step 5: Move git clone to its permanent home (if needed)
    log "Step 5/6: Moving git clone..."
    if [ "$repo_dest" = "$HOME/.aos/repo" ]; then
        mkdir -p "$(dirname "$repo_dest")"
        # Move the actual git clone (~/aos/) to ~/.aos/repo/
        mv "$AOS_LINK" "$repo_dest"
    else
        # Dev workspace already exists — just remove the old git clone
        rm -rf "$AOS_LINK"
    fi

    # Step 6: Create symlink
    log "Step 6/6: Creating symlink..."
    ln -sfn "$release_dir" "$AOS_LINK"

    # Record state
    echo "$current_hash" > "$HASH_FILE"

    # Update DEV_REPO for any subsequent commands in this session
    DEV_REPO="$repo_dest"

    # Verify
    if [ ! -L "$AOS_LINK" ]; then
        log "ERROR: Symlink creation failed — restoring backup"
        rm -f "$AOS_LINK" 2>/dev/null
        mv "$HOME/aos-backup" "$AOS_LINK"
        release_lock
        exit 1
    fi

    if [ ! -f "$AOS_LINK/VERSION" ]; then
        log "ERROR: Symlink doesn't resolve to valid release — restoring backup"
        rm -f "$AOS_LINK"
        mv "$HOME/aos-backup" "$AOS_LINK"
        release_lock
        exit 1
    fi

    log ""
    log "Conversion complete!"
    log "  ~/aos → $release_dir"
    log "  Git clone: $repo_dest"
    log "  Backup: ~/aos-backup/ (safe to delete after verification)"
    log ""
    log "Run 'aos self-test' to verify, then 'rm -rf ~/aos-backup' when satisfied."
}

# ── Main ───────────────────────────────────────────────────────────────────

case "${1:-help}" in
    create)   create ;;
    activate) activate "${2:-}" ;;
    rollback) rollback ;;
    list)     list_releases ;;
    prune)    prune "${2:-5}" ;;
    current)  current ;;
    convert)  convert ;;
    *)
        echo "Usage: release-manager <command>"
        echo ""
        echo "Commands:"
        echo "  create              Create release from origin/main"
        echo "  activate <version>  Switch ~/aos to a release"
        echo "  rollback            Switch to previous release"
        echo "  list                Show all releases"
        echo "  prune [N]           Keep last N releases (default 5)"
        echo "  current             Show active release"
        echo "  convert             Convert git-clone ~/aos/ to release system"
        exit 1
        ;;
esac
