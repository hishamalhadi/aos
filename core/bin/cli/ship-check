# 8. IMPORT HEALTH — critical modules must import cleanly
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
echo ""
echo "Import Health"
echo "─────────────"

# Smoke-test that key engine modules can be imported without crashing
# This catches broken sys.path references, missing db modules, etc.
import_smoke_errors=0
for entry in \
    "core.engine.comms.resolver:Comms resolver" \
    "core.engine.comms.orchestrator:Comms orchestrator" \
    "core.engine.comms.consumers.people_intel:People intelligence consumer" \
    "core.engine.work.cli:Work CLI" \
    "core.engine.work.inject_context:Context injection"; do
    mod="${entry%%:*}"
    label="${entry##*:}"
    mod_path=$(echo "$mod" | tr '.' '/')
    # Only test if the file exists in dev workspace
    if [[ -f "$DEV/${mod_path}.py" ]]; then
        err=$(python3 -c "
import sys, os
sys.path.insert(0, '$DEV')
os.chdir('$DEV')
try:
    __import__('${mod}')
except ImportError as e:
    print(f'ImportError: {e}')
    sys.exit(1)
except Exception:
    pass  # Non-import errors are OK (missing runtime deps, etc.)
" 2>&1)
        if [[ $? -ne 0 ]]; then
            fail "$label: $err"
            import_smoke_errors=$((import_smoke_errors + 1))
        fi
    fi
done
if [[ $import_smoke_errors -eq 0 ]]; then
    pass "Critical module imports OK"
fi


