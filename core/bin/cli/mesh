#!/usr/bin/env bash
# ─── AOS Mesh CLI ────────────────────────────────────────
#
# Manage the AOS mesh network — nodes, messaging, fleet health.
#
# Usage:
#   aos mesh init              Initialize mesh (admin only, one-time)
#   aos mesh invite <name>     Generate invite for a new node
#   aos mesh kick <name>       Remove a node from the mesh
#   aos mesh status            Show mesh status and connected nodes
#   aos mesh health            Fleet health overview (admin only)
#   aos mesh send <node> "msg" Send a message to another node
#   aos mesh nodes             List all nodes with details

set -euo pipefail

# shellcheck disable=SC2034
AOS_DIR="$HOME/aos"
MESH_CONFIG="$HOME/.aos/config/mesh.yaml"
MESH_DATA="$HOME/.aos/mesh"
HEADSCALE_DIR="$HOME/.aos/headscale"

# ── Colors ──────────────────────────────────────────────
if [[ -t 1 ]]; then
    GREEN='\033[0;32m'
    RED='\033[0;31m'
    YELLOW='\033[0;33m'
    BLUE='\033[0;34m'
    DIM='\033[0;90m'
    BOLD='\033[1m'
    NC='\033[0m'
else
    # shellcheck disable=SC2034
    GREEN='' RED='' YELLOW='' BLUE='' DIM='' BOLD='' NC=''
fi

# ── Helpers ─────────────────────────────────────────────
info()  { echo -e "${GREEN}●${NC} $*"; }
warn()  { echo -e "${YELLOW}⚠${NC} $*"; }
error() { echo -e "${RED}✗${NC} $*" >&2; }
dim()   { echo -e "${DIM}$*${NC}"; }

check_mesh_config() {
    if [[ ! -f "$MESH_CONFIG" ]]; then
        error "Mesh not initialized. Run 'aos mesh init' first."
        exit 1
    fi
}

get_config_value() {
    local key="$1"
    grep "^${key}:" "$MESH_CONFIG" 2>/dev/null | sed "s/^${key}:[[:space:]]*//" | tr -d '"' || echo ""
}

is_admin() {
    [[ "$(get_config_value role)" == "admin" ]]
}

# ── Commands ────────────────────────────────────────────

cmd_init() {
    echo -e "${BOLD}AOS Mesh — Initialize${NC}"
    echo ""

    if [[ -f "$MESH_CONFIG" ]]; then
        warn "Mesh already initialized."
        dim "  Config: $MESH_CONFIG"
        dim "  Role: $(get_config_value role)"
        dim "  Node: $(get_config_value node_name)"
        echo ""
        echo "  To reinitialize, remove $MESH_CONFIG and run again."
        exit 0
    fi

    # Check if Headscale is installed
    if ! command -v headscale &>/dev/null; then
        error "Headscale is not installed."
        echo ""
        echo "  Install it:"
        echo "    brew install headscale-cli"
        echo ""
        echo "  Or download the binary:"
        echo "    https://github.com/juanfont/headscale/releases"
        exit 1
    fi

    # Check if Tailscale client is installed
    if ! command -v tailscale &>/dev/null; then
        error "Tailscale client is not installed."
        echo ""
        echo "  Install from: https://tailscale.com/download/mac"
        exit 1
    fi

    # Create directories
    mkdir -p "$HEADSCALE_DIR" "$MESH_DATA" "$(dirname "$MESH_CONFIG")"

    # Get node name
    local node_name
    node_name=$(scutil --get LocalHostName 2>/dev/null | tr '[:upper:]' '[:lower:]' | tr ' ' '-' || hostname -s)

    # Generate Headscale config
    echo "  Generating Headscale configuration..."
    python3 - "$HEADSCALE_DIR" "$node_name" << 'INITPY'
import sys, json
from pathlib import Path

hs_dir = Path(sys.argv[1])
node_name = sys.argv[2]

# Headscale YAML config
# NOTE: Using port 8080 to avoid root requirement on macOS (ports < 1024).
# Embedded DERP is disabled because it requires HTTPS on server_url.
# For production, put Caddy in front on 443 → 8080, then enable DERP.
# For now, we use Tailscale's public DERP relays as fallback.
config_text = f"""# Headscale configuration for AOS Mesh
# Generated by: aos mesh init
#
# Port 8080: avoids root requirement on macOS.
# To enable embedded DERP later: set server_url to HTTPS, enable derp.server.

server_url: http://{node_name}.local:8080
listen_addr: 0.0.0.0:8080
metrics_listen_addr: 127.0.0.1:9090

private_key_path: {hs_dir}/private.key
noise:
  private_key_path: {hs_dir}/noise_private.key

prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

derp:
  server:
    enabled: false
    region_id: 999
    region_code: aos
    region_name: AOS Mesh
    stun_listen_addr: 0.0.0.0:3478
  urls:
    - https://controlplane.tailscale.com/derpmap/default
  paths: []
  auto_update_enabled: true
  update_frequency: 24h

database:
  type: sqlite
  sqlite:
    path: {hs_dir}/db.sqlite
    write_ahead_log: true

log:
  level: info

logtail:
  enabled: false

unix_socket: {hs_dir}/headscale.sock
unix_socket_permission: "0770"

dns:
  magic_dns: true
  base_domain: aos.mesh
  override_local_dns: false
  nameservers:
    global:
      - 1.1.1.1
      - 8.8.8.8
"""

config_path = hs_dir / "config.yaml"
config_path.write_text(config_text)
print(f"  Config: {config_path}")
INITPY

    # Write mesh config
    cat > "$MESH_CONFIG" << MESHYAML
# AOS Mesh — Node Configuration
role: admin
node_name: ${node_name}
admin_node: 127.0.0.1
mesh_port: 4100
headscale:
  config: ${HEADSCALE_DIR}/config.yaml
  url: http://${node_name}.local:8080
MESHYAML

    echo ""
    info "Mesh initialized as ${BOLD}admin${NC}"
    dim "  Node name: $node_name"
    dim "  Config:    $MESH_CONFIG"
    dim "  Headscale: $HEADSCALE_DIR/config.yaml"
    echo ""
    echo "  Next steps:"
    echo "    1. Start Headscale:"
    echo "       headscale serve -c $HEADSCALE_DIR/config.yaml"
    echo ""
    echo "    2. Create your user (in another terminal):"
    echo "       headscale -c $HEADSCALE_DIR/config.yaml users create $node_name"
    echo ""
    echo "    3. Connect this Mac to the mesh:"
    echo "       tailscale up --login-server http://${node_name}.local:8080"
    echo "       (Then approve the node in Headscale)"
    echo ""
    echo "    4. Invite others:"
    echo "       aos mesh invite <name>"
    echo ""
    echo "  NOTE: Headscale + Tailscale on the same machine is unsupported"
    echo "  upstream but works for basic setups. Test carefully."
}

cmd_invite() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        error "Usage: aos mesh invite <name>"
        exit 1
    fi

    check_mesh_config

    if ! is_admin; then
        error "Only the admin node can invite new nodes."
        exit 1
    fi

    echo -e "${BOLD}AOS Mesh — Invite ${name}${NC}"
    echo ""

    local hs_config="$HEADSCALE_DIR/config.yaml"

    # Create user in Headscale
    echo "  Creating user '$name'..."
    headscale -c "$hs_config" users create "$name" 2>/dev/null || dim "  (user may already exist)"

    # Generate pre-auth key (v0.28.0: --user takes numeric ID)
    echo "  Generating auth key..."
    local user_id
    user_id=$(headscale -c "$hs_config" users list -o json 2>/dev/null | \
        python3 -c "import sys,json; [print(u['id']) for u in json.load(sys.stdin) if u.get('name')=='$name']" 2>/dev/null)

    if [[ -z "$user_id" ]]; then
        error "Could not find user ID for '$name'."
        exit 1
    fi

    local auth_key
    auth_key=$(headscale -c "$hs_config" preauthkeys create --user "$user_id" --reusable --expiration 720h 2>&1 | grep -oE 'hskey-[a-zA-Z0-9_-]+' | head -1)

    if [[ -z "$auth_key" ]]; then
        error "Failed to generate auth key. Is Headscale running?"
        echo "  Start it first: headscale serve -c $hs_config"
        exit 1
    fi

    local node_name admin_ip
    node_name=$(get_config_value node_name)
    admin_ip=$(tailscale ip -4 2>/dev/null || echo "<admin-tailscale-ip>")

    # Generate invite file
    local invite_file="$MESH_DATA/${name}-invite.txt"
    cat > "$invite_file" << INVITE
# ─── AOS Mesh Invite ────────────────────────────────────
# For: ${name}
# From: ${node_name}
# Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)
# Expires: 24 hours
#
# Step 1: Install Tailscale (if not already installed)
#   https://tailscale.com/download/mac
#
# Step 2: Run this command:

tailscale up --login-server http://${node_name}.local:8080 --authkey ${auth_key}

# Step 3: Verify with 'tailscale status'
#
# Step 4: Configure AOS mesh — create ~/.aos/config/mesh.yaml:
#
#   role: node
#   node_name: ${name}
#   admin_node: ${admin_ip}
#   mesh_port: 4100
#
# ─────────────────────────────────────────────────────────
INVITE

    echo ""
    info "Invite generated for ${BOLD}${name}${NC}"
    dim "  File: $invite_file"
    dim "  Key expires in 24 hours"
    echo ""
    echo "  Send this file to $name securely."
}

cmd_kick() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        error "Usage: aos mesh kick <name>"
        exit 1
    fi

    check_mesh_config

    if ! is_admin; then
        error "Only the admin node can remove nodes."
        exit 1
    fi

    echo -e "${BOLD}AOS Mesh — Remove ${name}${NC}"
    echo ""

    local hs_config="$HEADSCALE_DIR/config.yaml"

    # Delete nodes belonging to this user, then the user
    echo "  Removing $name's nodes from Headscale..."
    # List node IDs for this user and delete each
    headscale -c "$hs_config" nodes list --user "$name" --output json 2>/dev/null | \
        python3 -c "
import sys, json
try:
    nodes = json.load(sys.stdin)
    for n in nodes:
        print(n.get('id', ''))
except: pass
" 2>/dev/null | while read -r nid; do
        [[ -n "$nid" ]] && headscale -c "$hs_config" nodes delete --identifier "$nid" --force 2>/dev/null
    done

    echo "  Removing user '$name'..."
    headscale -c "$hs_config" users destroy --name "$name" --force 2>/dev/null || true

    # Remove from local roster
    if [[ -f "$MESH_DATA/roster.json" ]]; then
        python3 -c "
import json
p = '$MESH_DATA/roster.json'
d = json.loads(open(p).read())
d['nodes'] = [n for n in d.get('nodes', []) if n.get('node') != '$name']
open(p, 'w').write(json.dumps(d, indent=2))
" 2>/dev/null || true
    fi

    echo ""
    info "${name} removed from the mesh"
    dim "  Keys revoked — they cannot reconnect."
}

cmd_status() {
    check_mesh_config

    local role node_name
    role=$(get_config_value role)
    node_name=$(get_config_value node_name)

    echo -e "${BOLD}AOS Mesh${NC}"
    echo -e "  Node: ${BOLD}${node_name}${NC}  Role: ${role}"
    echo ""

    # Check mesh service
    if curl -s "http://127.0.0.1:4100/health" >/dev/null 2>&1; then
        info "Mesh service: running"
    else
        warn "Mesh service: not running"
    fi

    # Check Tailscale
    if command -v tailscale &>/dev/null && tailscale status &>/dev/null; then
        info "Tailscale: connected"
        echo ""
        echo "  Nodes:"
        tailscale status 2>/dev/null | while IFS= read -r line; do
            echo "    $line"
        done
    else
        warn "Tailscale: not connected"
    fi

    # Fleet summary (admin only)
    if [[ "$role" == "admin" ]]; then
        local fleet
        fleet=$(curl -s "http://127.0.0.1:4100/fleet/health" 2>/dev/null || echo "")
        if [[ -n "$fleet" ]] && echo "$fleet" | python3 -c "import sys,json; json.load(sys.stdin)" 2>/dev/null; then
            echo ""
            echo -e "  ${BOLD}Fleet:${NC}"
            echo "$fleet" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f'    Online: {d.get(\"online\",0)}/{d.get(\"total\",0)}  Healthy: {d.get(\"healthy\",0)}  Errors: {d.get(\"errors\",0)}')
for n in d.get('nodes', []):
    s = '\033[0;32m●\033[0m' if n.get('status') == 'online' else '\033[0;90m○\033[0m'
    print(f'    {s} {n.get(\"node\",\"?\"):<16} {n.get(\"health\",\"?\"):<10} v{n.get(\"version\",\"?\")}')
" 2>/dev/null
        fi
    fi
}

cmd_health() {
    check_mesh_config

    if ! is_admin; then
        error "Fleet health is admin-only. Use 'aos mesh status' for local status."
        exit 1
    fi

    echo -e "${BOLD}AOS Mesh — Fleet Health${NC}"
    echo ""

    local fleet
    fleet=$(curl -s "http://127.0.0.1:4100/fleet/health" 2>/dev/null)

    if [[ -z "$fleet" ]]; then
        error "Cannot reach mesh service. Is meshd running?"
        exit 1
    fi

    echo "$fleet" | python3 -c "
import sys, json
d = json.load(sys.stdin)

print(f'  Nodes: {d.get(\"online\",0)}/{d.get(\"total\",0)} online')
print(f'  Healthy: {d.get(\"healthy\",0)}  Warnings: {d.get(\"warnings\",0)}  Errors: {d.get(\"errors\",0)}')
print()

for n in sorted(d.get('nodes', []), key=lambda x: x.get('node', '')):
    s = '\033[0;32m●\033[0m' if n.get('status') == 'online' else '\033[0;90m○\033[0m'
    name = n.get('node', '?')
    health = n.get('health', '?')
    ver = n.get('version', '?')
    up = n.get('uptime', 0)
    days, rem = divmod(up, 86400)
    hours = rem // 3600
    upstr = f'{days}d {hours}h' if days else f'{hours}h'
    errs = n.get('errors', [])
    err_str = f'  ({errs[0]})' if errs else ''
    print(f'  {s} {name:<16} {health:<10} v{ver:<8} up {upstr}{err_str}')

recent = d.get('recent_errors', [])
if recent:
    print()
    print('  Recent errors:')
    for e in recent[-5:]:
        ts = e.get('timestamp', '?')[:16]
        print(f'    [{ts}] {e.get(\"node\",\"?\")}: {e.get(\"error\",\"?\")}')
"
}

cmd_send() {
    local target="${1:-}"
    local message="${2:-}"

    if [[ -z "$target" ]] || [[ -z "$message" ]]; then
        error "Usage: aos mesh send <node> \"message\""
        exit 1
    fi

    check_mesh_config

    local node_name
    node_name=$(get_config_value node_name)

    # Resolve target IP via Tailscale
    local target_ip
    target_ip=$(tailscale status --json 2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)
target = '$target'.lower()
for _, p in d.get('Peer', {}).items():
    if p.get('HostName', '').lower() == target:
        addrs = p.get('TailscaleIPs', [])
        if addrs: print(addrs[0]); break
" 2>/dev/null)

    if [[ -z "$target_ip" ]]; then
        error "Node '$target' not found on the mesh."
        dim "  Run 'aos mesh status' to see connected nodes."
        exit 1
    fi

    # Build and send message
    local payload
    payload=$(python3 -c "
import json, uuid
from datetime import datetime, timezone
print(json.dumps({
    'from': '$node_name',
    'to': '$target',
    'type': 'text',
    'payload': {'message': $(python3 -c "import json; print(json.dumps('$message'))")},
    'id': 'msg_' + uuid.uuid4().hex[:8],
    'timestamp': datetime.now(timezone.utc).isoformat(),
}))
")

    local response
    response=$(curl -s -X POST "http://${target_ip}:4100/message" \
        -H "Content-Type: application/json" \
        -d "$payload" 2>/dev/null)

    if echo "$response" | grep -q '"received"'; then
        info "Message sent to ${BOLD}${target}${NC}"
    else
        error "Failed to send to $target"
        dim "  $response"
    fi
}

# ── Dispatch ────────────────────────────────────────────

case "${1:-help}" in
    init)    cmd_init ;;
    invite)  cmd_invite "${2:-}" ;;
    kick)    cmd_kick "${2:-}" ;;
    status)  cmd_status ;;
    health)  cmd_health ;;
    send)    cmd_send "${2:-}" "${3:-}" ;;
    nodes)   tailscale status 2>/dev/null || error "Tailscale not connected" ;;
    query)   echo "Federated search — coming in Phase 4"; exit 0 ;;
    feed)    echo "Agent feed — coming in Phase 5"; exit 0 ;;
    help|*)
        echo "AOS Mesh — Multi-node agent network"
        echo ""
        echo "Usage: aos mesh <command>"
        echo ""
        echo "Commands:"
        echo "  init              Initialize mesh (admin only)"
        echo "  invite <name>     Generate invite for a new node"
        echo "  kick <name>       Remove a node from the mesh"
        echo "  status            Show mesh status"
        echo "  health            Fleet health (admin only)"
        echo "  send <node> msg   Send message to a node"
        echo "  nodes             List connected nodes"
        echo "  query \"terms\"     Federated search (Phase 4)"
        echo "  feed              Agent activity feed (Phase 5)"
        ;;
esac
