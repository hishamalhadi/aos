#!/usr/bin/env python3
"""Watch for new iMessages from a specific contact. Exits when a new message arrives."""

import sqlite3
import shutil
import tempfile
import time
import sys
import json
from pathlib import Path

DB_PATH = Path.home() / "Library/Messages/chat.db"
MAC_EPOCH = 978307200
NS = 1_000_000_000

def get_latest_from(handle_filter: str) -> list[dict]:
    if not DB_PATH.exists():
        return []
    tmp = tempfile.NamedTemporaryFile(suffix=".sqlite", delete=False)
    tmp.close()
    try:
        shutil.copy2(DB_PATH, tmp.name)
        for ext in ["-wal", "-shm"]:
            w = DB_PATH.parent / (DB_PATH.name + ext)
            if w.exists():
                shutil.copy2(w, tmp.name + ext)
    except PermissionError:
        return []

    conn = sqlite3.connect(tmp.name)
    conn.row_factory = sqlite3.Row
    rows = conn.execute("""
        SELECT m.text, m.date, m.is_from_me, h.id as handle
        FROM message m
        LEFT JOIN handle h ON m.handle_id = h.rowid
        WHERE m.text IS NOT NULL AND m.text != ''
          AND h.id LIKE ?
        ORDER BY m.date DESC LIMIT 5
    """, (f"%{handle_filter}%",)).fetchall()

    msgs = []
    for r in rows:
        import datetime
        ts = r["date"] / NS + MAC_EPOCH
        dt = datetime.datetime.fromtimestamp(ts)
        msgs.append({
            "text": r["text"],
            "time": dt.isoformat(),
            "from_me": bool(r["is_from_me"]),
        })
    conn.close()
    Path(tmp.name).unlink(missing_ok=True)
    for ext in ["-wal", "-shm"]:
        Path(tmp.name + ext).unlink(missing_ok=True)
    return msgs

if __name__ == "__main__":
    handle = sys.argv[1] if len(sys.argv) > 1 else ""
    timeout = int(sys.argv[2]) if len(sys.argv) > 2 else 300

    # Get current latest message count/text to detect new ones
    initial = get_latest_from(handle)
    initial_latest = initial[0]["text"] if initial else ""
    initial_count = len(initial)

    elapsed = 0
    while elapsed < timeout:
        time.sleep(10)
        elapsed += 10
        current = get_latest_from(handle)
        if not current:
            continue
        # Check if there's a new message that's NOT from me
        new_msgs = []
        for m in current:
            if not m["from_me"] and m["text"] != initial_latest:
                new_msgs.append(m)
                break
        if new_msgs or (current and not current[0]["from_me"] and current[0]["text"] != initial_latest):
            # New incoming message detected
            latest = current[0] if not current[0]["from_me"] else None
            if latest:
                print(json.dumps(latest))
                sys.exit(0)

    print(json.dumps({"timeout": True}))
    sys.exit(0)
