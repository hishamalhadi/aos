#!/usr/bin/env python3
"""morning-context — fetches weather and prayer times for the day.

Runs at 06:30 daily. Writes to ~/.aos/work/morning-context.yaml.
Uses only stdlib — no pip dependencies.
"""

import datetime
import json
import os
import sys
import urllib.parse
import urllib.request
from pathlib import Path

OUTPUT_FILE = Path.home() / ".aos" / "work" / "morning-context.yaml"

# Configurable via environment
CITY = os.environ.get("AOS_CITY", "Houston")
COUNTRY = os.environ.get("AOS_COUNTRY", "US")
PRAYER_METHOD = os.environ.get("AOS_PRAYER_METHOD", "2")

REQUEST_TIMEOUT = 10


def _fetch_url(url: str) -> dict | None:
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "aos-morning-context/1.0"})
        with urllib.request.urlopen(req, timeout=REQUEST_TIMEOUT) as resp:
            return json.loads(resp.read().decode())
    except Exception as e:
        print(f"Warning: Failed to fetch {url}: {e}")
        return None


def _get_weather() -> dict:
    data = _fetch_url("https://wttr.in/?format=j1")
    if not data:
        return {"condition": "unavailable", "summary": "Weather fetch failed"}

    try:
        current = data["current_condition"][0]
        today = data["weather"][0]

        condition = current.get("weatherDesc", [{}])[0].get("value", "Unknown")
        temp_high_c = today.get("maxtempC", "?")
        temp_low_c = today.get("mintempC", "?")
        humidity = current.get("humidity", "?")

        # Convert C to F
        def c_to_f(c):
            try:
                return f"{round(int(c) * 9/5 + 32)}°F"
            except (ValueError, TypeError):
                return f"{c}°C"

        temp_high = c_to_f(temp_high_c)
        temp_low = c_to_f(temp_low_c)

        return {
            "condition": condition,
            "temp_high": temp_high,
            "temp_low": temp_low,
            "humidity": f"{humidity}%",
            "summary": f"{condition}, high {temp_high}",
        }
    except (KeyError, IndexError, TypeError) as e:
        print(f"Warning: Weather parse failed: {e}")
        return {"condition": "parse error", "summary": "Weather parse failed"}


def _get_prayer_times() -> dict:
    date_str = datetime.date.today().strftime("%d-%m-%Y")
    url = (
        f"https://api.aladhan.com/v1/timingsByCity/{date_str}"
        f"?city={urllib.parse.quote(CITY)}&country={urllib.parse.quote(COUNTRY)}"
        f"&method={PRAYER_METHOD}"
    )

    data = _fetch_url(url)
    if not data:
        return {}

    try:
        timings = data["data"]["timings"]
        return {
            "fajr": timings.get("Fajr", "?"),
            "sunrise": timings.get("Sunrise", "?"),
            "dhuhr": timings.get("Dhuhr", "?"),
            "asr": timings.get("Asr", "?"),
            "maghrib": timings.get("Maghrib", "?"),
            "isha": timings.get("Isha", "?"),
        }
    except (KeyError, TypeError) as e:
        print(f"Warning: Prayer times parse failed: {e}")
        return {}


def _write_yaml(data: dict, path: Path):
    """Write dict as YAML using stdlib (no pyyaml required).

    Supports flat dicts, one level of nested dicts, and top-level lists
    of dicts (e.g. `people_today`).
    """
    lines = []

    def _val(v):
        if isinstance(v, str):
            if any(c in v for c in ('"', "'", ":", "#", "{", "}", "[", "]", ",")):
                escaped = v.replace('"', '\\"')
                return f'"{escaped}"'
            return v
        return str(v)

    for key, value in data.items():
        if isinstance(value, dict):
            lines.append(f"{key}:")
            for k2, v2 in value.items():
                lines.append(f"  {k2}: {_val(str(v2))}")
        elif isinstance(value, list):
            lines.append(f"{key}:")
            for item in value:
                if isinstance(item, dict):
                    first = True
                    for k2, v2 in item.items():
                        prefix = "  - " if first else "    "
                        lines.append(f"{prefix}{k2}: {_val(str(v2))}")
                        first = False
                else:
                    lines.append(f"  - {_val(str(item))}")
        else:
            lines.append(f"{key}: {_val(str(value))}")

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text("\n".join(lines) + "\n")


def _get_people_nudges() -> list:
    """Refresh and read top live nudges from people.db. Never crashes."""
    try:
        import sqlite3
        # Resolve project root from this script's location so the import
        # works from both the runtime tree (~/aos) and the dev workspace.
        project_root = Path(__file__).resolve().parents[3]
        sys.path.insert(0, str(project_root))
        from core.engine.people.intel import nudges as nudges_mod  # type: ignore

        db_path = Path.home() / ".aos" / "data" / "people.db"
        if not db_path.exists():
            return []
        conn = sqlite3.connect(str(db_path))
        conn.row_factory = sqlite3.Row
        try:
            nudges_mod.generate_all(conn)
            live = nudges_mod.list_live_nudges(conn, limit=5)
        finally:
            conn.close()
        return [
            {
                "person_id": n["person_id"],
                "name": n["name"] or "",
                "type": n["surface_type"],
                "prompt": n["content"],
            }
            for n in live
        ]
    except Exception as e:
        print(f"Warning: people-nudges refresh failed: {e}")
        return []


def main():
    print(f"[{datetime.datetime.now().strftime('%H:%M:%S')}] morning-context starting")

    today = datetime.date.today().isoformat()
    now = datetime.datetime.now().isoformat(timespec="seconds")

    print(f"Fetching weather ({CITY}, {COUNTRY})...")
    weather = _get_weather()

    print(f"Fetching prayer times ({CITY}, {COUNTRY}, method {PRAYER_METHOD})...")
    prayer_times = _get_prayer_times()

    print("Refreshing people nudges...")
    people_today = _get_people_nudges()

    context = {
        "date": today,
        "generated": now,
        "weather": weather,
        "prayer_times": prayer_times,
        "people_today": people_today,
    }

    _write_yaml(context, OUTPUT_FILE)
    print(f"Morning context written: {OUTPUT_FILE}")

    if weather.get("summary"):
        print(f"  Weather: {weather['summary']}")
    if prayer_times.get("fajr"):
        print(f"  Fajr: {prayer_times['fajr']}, Maghrib: {prayer_times.get('maghrib', '?')}")
    if people_today:
        print(f"  People nudges: {len(people_today)} live")

    print(f"[{datetime.datetime.now().strftime('%H:%M:%S')}] morning-context done")


if __name__ == "__main__":
    main()
