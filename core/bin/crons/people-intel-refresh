#!/bin/bash
# people-intel-refresh — nightly refresh of People Intelligence state.
# Runs at 02:00 via cron.
#
# Three steps, each idempotent and safe to re-run:
#   1. Re-extract signals from all 9 source adapters → signal_store
#   2. Re-classify all persons (rule-based, no LLM) → person_classification
#   3. Generate nudges from current state → intelligence_queue
#
# Each step's exit code is captured but the script always continues —
# a single failing step should not block the others. The script exits 0
# unless every step failed.
set -u

# Resolve project root from the script's own location so the cron works
# from runtime (~/aos) and dev (/Volumes/AOS-X/project/aos) without tweaks.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AOS_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
PYTHON="${PYTHON:-python3}"

cd "$AOS_ROOT" || { echo "[people-intel-refresh] cannot cd to $AOS_ROOT" >&2; exit 1; }

ts() { date '+%Y-%m-%d %H:%M:%S'; }

failures=0
successes=0

run_step() {
    local label="$1"
    shift
    echo "[$(ts)] $label starting"
    if "$@"; then
        echo "[$(ts)] $label ok"
        successes=$((successes + 1))
    else
        echo "[$(ts)] $label FAILED (exit $?)" >&2
        failures=$((failures + 1))
    fi
}

run_step "extract"          "$PYTHON" -m core.engine.people.intel.cli extract
run_step "classify"         "$PYTHON" -m core.engine.people.intel.cli classify
run_step "nudges-generate"  "$PYTHON" -m core.engine.people.intel.cli nudges-generate

echo "[$(ts)] people-intel-refresh done — $successes ok, $failures failed"

# Only fail if every step failed.
if [ "$successes" -eq 0 ]; then
    exit 1
fi
exit 0
