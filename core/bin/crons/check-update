#!/usr/bin/env bash
# check-update — checks if a new AOS version is available
#
# Usage:
#   check-update              — check and notify if update available
#   check-update --apply      — check and auto-apply if available
#   check-update --status     — just print current vs remote version
#
# Called by:
#   - Scheduler (crons.yaml) every 2 hours
#   - User via `aos check-update`
#   - Dashboard update button

set +e

AOS_DIR="$HOME/aos"
STATE_FILE="$HOME/.aos/data/update-state.json"
LOG_PREFIX="[$(date '+%Y-%m-%d %H:%M:%S')]"

mkdir -p "$(dirname "$STATE_FILE")"

log() { echo "$LOG_PREFIX $*"; }

# ── Telegram notification (best-effort) ──────────────────────────────────────

notify() {
    local msg="$1"
    local bot_token chat_id
    bot_token=$("$AOS_DIR/core/bin/cli/agent-secret" get TELEGRAM_BOT_TOKEN 2>/dev/null) || return 0
    chat_id=$("$AOS_DIR/core/bin/cli/agent-secret" get TELEGRAM_CHAT_ID 2>/dev/null) || return 0
    [[ -z "$bot_token" || -z "$chat_id" ]] && return 0

    curl -s --max-time 10 -X POST "https://api.telegram.org/bot${bot_token}/sendMessage" \
        -H "Content-Type: application/json" \
        -d "{\"chat_id\": ${chat_id}, \"text\": \"${msg}\", \"parse_mode\": \"HTML\"}" \
        > /dev/null 2>&1 || true
}

# ── Check for updates ────────────────────────────────────────────────────────

check() {
    cd "$AOS_DIR" || { log "ERROR: AOS dir not found"; exit 1; }

    # Ensure we have a remote
    local remote
    remote=$(git remote 2>/dev/null | head -1)
    if [[ -z "$remote" ]]; then
        log "No git remote configured — skipping update check"
        return 1
    fi

    # Fetch latest (quiet, no merge)
    git fetch "$remote" --quiet 2>/dev/null || {
        log "WARN: git fetch failed (network?)"
        return 1
    }

    local branch
    branch=$(git branch --show-current 2>/dev/null || echo "main")
    local local_hash remote_hash
    local_hash=$(git rev-parse HEAD 2>/dev/null)
    remote_hash=$(git rev-parse "$remote/$branch" 2>/dev/null)

    if [[ -z "$remote_hash" ]]; then
        log "WARN: could not resolve remote branch"
        return 1
    fi

    if [[ "$local_hash" == "$remote_hash" ]]; then
        log "Up to date"
        # Write state
        python3 -c "
import json, datetime
state = {
    'last_check': datetime.datetime.now().isoformat(),
    'status': 'up_to_date',
    'local': '$local_hash',
    'remote': '$remote_hash',
}
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
"
        return 0
    fi

    # Count new commits
    local ahead behind
    ahead=$(git rev-list --count "$remote/$branch..HEAD" 2>/dev/null || echo 0)
    behind=$(git rev-list --count "HEAD..$remote/$branch" 2>/dev/null || echo 0)

    # Get commit summaries
    local changes
    changes=$(git log --oneline "HEAD..$remote/$branch" 2>/dev/null | head -5)

    log "Update available: $behind new commit(s)"

    # Write state
    python3 -c "
import json, datetime
state = {
    'last_check': datetime.datetime.now().isoformat(),
    'status': 'update_available',
    'local': '$local_hash',
    'remote': '$remote_hash',
    'behind': $behind,
    'ahead': $ahead,
    'changes': '''$changes'''.strip().split('\n'),
}
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
"

    return 2  # 2 = update available
}

# ── Apply update ─────────────────────────────────────────────────────────────

apply() {
    log "Applying update..."

    cd "$AOS_DIR" || exit 1

    # Snapshot for rollback
    local old_hash
    old_hash=$(git rev-parse HEAD 2>/dev/null)
    local old_version
    old_version=$(cat "$AOS_DIR/VERSION" 2>/dev/null || echo "unknown")

    # Pull (main branch only, fast-forward)
    local pull_output
    pull_output=$(git pull --ff-only origin main 2>&1)
    local pull_status=$?

    if [[ $pull_status -ne 0 ]]; then
        log "ERROR: git pull failed — attempting reset"
        # Reset any dirty state and try again
        git checkout -- . 2>/dev/null
        pull_output=$(git pull --ff-only origin main 2>&1)
        pull_status=$?
        if [[ $pull_status -ne 0 ]]; then
            log "ERROR: git pull failed after reset"
            notify "⚠️ System update failed. Will retry next cycle."
            return 1
        fi
    fi

    local new_version
    new_version=$(cat "$AOS_DIR/VERSION" 2>/dev/null || echo "unknown")

    # Always run reconcile — even if version didn't change.
    # Catches drift from Homebrew updates, manual edits, etc.
    log "Running reconcile..."
    "$AOS_DIR/core/bin/internal/aos-python" "$AOS_DIR/core/infra/reconcile/runner.py" run 2>>"$HOME/.aos/logs/reconcile-stderr.log" || true

    # Skip the rest if version didn't change
    if [[ "$old_version" == "$new_version" ]]; then
        log "No version change ($old_version)"
        return 0
    fi

    log "Updating $old_version → $new_version"

    # Run migrations
    log "Running migrations..."
    "$AOS_DIR/core/bin/internal/aos-python" "$AOS_DIR/core/infra/migrations/runner.py" migrate 2>/dev/null || true

    # Sync skills, agents, rules, and MCP servers
    log "Syncing..."
    bash "$AOS_DIR/core/bin/cli/aos" sync-skills 2>/dev/null || true
    bash "$AOS_DIR/core/bin/cli/aos" sync-agents 2>/dev/null || true
    bash "$AOS_DIR/core/bin/cli/aos" sync-rules 2>/dev/null || true
    bash "$AOS_DIR/core/bin/cli/aos" sync-mcp 2>/dev/null || true

    # Check if any pyproject.toml or requirements.lock changed — rebuild affected venvs
    local changed_services
    changed_services=$(git diff --name-only "$old_hash..HEAD" 2>/dev/null | grep -E "core/services/.*/(pyproject\.toml|requirements\.lock)" | sed 's|core/services/\([^/]*\)/.*|\1|' | sort -u || true)
    if [[ -n "$changed_services" ]]; then
        log "Dependencies changed in: $changed_services"
        for svc in $changed_services; do
            log "Rebuilding $svc venv..."
            rm -rf "$HOME/.aos/services/$svc/.venv"
            bash "$AOS_DIR/core/bin/cli/aos" deploy "$svc" 2>/dev/null || true
        done
    fi

    # Reload services if bridge or dashboard code changed
    local reload_bridge=false reload_dashboard=false reload_listen=false
    git diff --name-only "$old_hash..HEAD" 2>/dev/null | grep -q "core/services/bridge/" && reload_bridge=true
    git diff --name-only "$old_hash..HEAD" 2>/dev/null | grep -q "core/services/dashboard/" && reload_dashboard=true
    git diff --name-only "$old_hash..HEAD" 2>/dev/null | grep -q "core/services/listen/" && reload_listen=true

    # Use bootout/bootstrap/kickstart instead of unload/load to avoid launchd throttling.
    # See GitHub issue #6: unload/load doesn't reset the throttle counter, so services
    # that crash during update stay dead even after reload.
    local uid=$(id -u)
    if [[ "$reload_bridge" == true ]]; then
        log "Restarting bridge (kickstart)..."
        launchctl bootout "gui/$uid/com.aos.bridge" 2>/dev/null
        launchctl bootstrap "gui/$uid" "$HOME/Library/LaunchAgents/com.aos.bridge.plist" 2>/dev/null
        launchctl kickstart -k "gui/$uid/com.aos.bridge" 2>/dev/null
    fi
    if [[ "$reload_dashboard" == true ]]; then
        log "Restarting dashboard (kickstart)..."
        launchctl bootout "gui/$uid/com.aos.dashboard" 2>/dev/null
        launchctl bootstrap "gui/$uid" "$HOME/Library/LaunchAgents/com.aos.dashboard.plist" 2>/dev/null
        launchctl kickstart -k "gui/$uid/com.aos.dashboard" 2>/dev/null
    fi
    if [[ "$reload_listen" == true ]]; then
        log "Restarting listen (kickstart)..."
        launchctl bootout "gui/$uid/com.aos.listen" 2>/dev/null
        launchctl bootstrap "gui/$uid" "$HOME/Library/LaunchAgents/com.aos.listen.plist" 2>/dev/null
        launchctl kickstart -k "gui/$uid/com.aos.listen" 2>/dev/null
    fi

    # Health check after update — poll with retries
    # Python services with venvs need time to import and initialize
    local health_ok=false
    local max_attempts=6
    local attempt=0
    while [[ $attempt -lt $max_attempts ]]; do
        sleep 2
        attempt=$((attempt + 1))
        local all_up=true
        for svc in bridge dashboard listen; do
            if ! launchctl list 2>/dev/null | grep -q "com.aos.$svc"; then
                all_up=false
                break
            fi
        done
        if [[ "$all_up" == true ]]; then
            health_ok=true
            break
        fi
        [[ $attempt -lt $max_attempts ]] && log "Health check attempt $attempt/$max_attempts — waiting..."
    done

    if [[ "$health_ok" == false ]]; then
        # Log which services are actually down
        for svc in bridge dashboard listen; do
            if ! launchctl list 2>/dev/null | grep -q "com.aos.$svc"; then
                log "WARN: $svc not running after update"
            fi
        done
    fi

    if [[ "$health_ok" == false ]]; then
        # Do NOT rollback code after migrations have run.
        # Migrations may have changed data layout (vault, instance dirs, config).
        # Rolling back code while data is in the new layout creates a worse state
        # than having a service temporarily down.
        log "Health check failed after update to $new_version — services may need manual restart"
        log "NOT rolling back: migrations already applied to data layer"

        # Try one more restart of failed services
        for svc in bridge dashboard listen; do
            if ! launchctl list 2>/dev/null | grep -q "com.aos.$svc"; then
                log "Attempting restart of $svc..."
                launchctl bootout "gui/$uid/com.aos.$svc" 2>/dev/null
                launchctl bootstrap "gui/$uid" "$HOME/Library/LaunchAgents/com.aos.${svc}.plist" 2>/dev/null
                launchctl kickstart -k "gui/$uid/com.aos.$svc" 2>/dev/null
            fi
        done

        notify "⚠️ Update to $new_version applied but some services are unhealthy. Attempting restart. Check 'aos status' if issues persist."
        bash "$AOS_DIR/core/bin/cli/feedback" --auto "Update $new_version: services unhealthy post-update" "auto-update" 2>/dev/null || true
        # Don't return 1 — the update DID apply. Just services need attention.
    fi

    # Read release notes from CHANGELOG.md
    local release_notes
    release_notes=$(python3 -c "
from pathlib import Path
import re

cl = Path('$AOS_DIR/CHANGELOG.md')
if not cl.exists():
    print('System updated.')
    raise SystemExit()

content = cl.read_text()

# Find the section for this version (match v0.3.0, not v0.3.0-beta)
pattern = r'## ${new_version}\b.*?\n(.*?)(?=\n## v|\Z)'
match = re.search(pattern, content, re.DOTALL)
if not match:
    print('System updated.')
    raise SystemExit()

notes = match.group(1).strip()
lines = [l.strip() for l in notes.split('\n') if l.strip()]

# Extract summary and categorized changes
# New format: first non-bullet line is the summary, bullets start with '- Verb ...'
# Legacy format: 'Summary: ...' prefix, 'Verb: ...' entries
summary = ''
changes = {'Added': [], 'Changed': [], 'Fixed': [], 'Removed': []}
# Also match rewording verbs to their base category
verb_map = {'Added': 'Added', 'Changed': 'Changed', 'Fixed': 'Fixed', 'Removed': 'Removed',
            'Rewrote': 'Changed', 'Expanded': 'Changed', 'Moved': 'Changed'}
other = []

for line in lines:
    # Legacy: 'Summary: ...'
    if line.startswith('Summary:'):
        summary = line.replace('Summary:', '').strip()
    # Bullet: '- Added foo', '- Fixed bar', '- Rewrote baz'
    elif line.startswith('- '):
        text = line[2:]
        matched = False
        for verb, cat in verb_map.items():
            if text.startswith(verb + ' '):
                changes[cat].append(text[len(verb)+1:])
                matched = True
                break
        if not matched:
            other.append(text)
    # Legacy: 'Added: foo'
    elif ':' in line and line.split(':')[0] in changes:
        cat = line.split(':')[0]
        rest = ':'.join(line.split(':')[1:]).strip().lstrip('- ')
        changes[cat].append(rest)
    # Plain line before any bullets = summary
    elif not line.startswith('#') and not summary:
        summary = line
    elif not line.startswith('#'):
        other.append(line)

# Build conversational Telegram message
# Focus on what's NEW (Added section) — that's what users care about
if summary:
    print(summary)
    print()

# Show categorized changes with emoji prefixes
icons = {'Added': '✦', 'Changed': '↻', 'Fixed': '✓', 'Removed': '✕'}
for cat in ['Added', 'Changed', 'Fixed', 'Removed']:
    items = changes[cat]
    if not items:
        continue
    icon = icons[cat]
    for item in items[:8]:
        print(f'{icon} {item}')
    if len(items) > 8:
        print(f'  ... and {len(items)-8} more')

if other:
    for line in other[:3]:
        print(f'  {line}')
" 2>/dev/null)

    # Update state
    local new_hash
    new_hash=$(git rev-parse HEAD 2>/dev/null)
    python3 -c "
import json, datetime
state = {
    'last_check': datetime.datetime.now().isoformat(),
    'last_update': datetime.datetime.now().isoformat(),
    'status': 'up_to_date',
    'version': '$new_version',
    'local': '$new_hash',
    'remote': '$new_hash',
}
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
"

    log "Update complete: $new_version"

    # Send release notification
    local note_text
    note_text="━━━━━━━━━━━━━━━━━━
AOS $new_version
━━━━━━━━━━━━━━━━━━

$release_notes

Already applied. No action needed."
    notify "$note_text"
}

# ── Status ───────────────────────────────────────────────────────────────────

status() {
    if [[ -f "$STATE_FILE" ]]; then
        python3 -c "
import json
with open('$STATE_FILE') as f:
    s = json.load(f)
print(f\"  Status:     {s.get('status', 'unknown')}\")
print(f\"  Last check: {s.get('last_check', 'never')}\")
if s.get('behind', 0) > 0:
    print(f\"  Behind:     {s['behind']} commit(s)\")
    for c in s.get('changes', []):
        print(f\"    {c}\")
if s.get('last_update'):
    print(f\"  Last update: {s['last_update']}\")
"
    else
        echo "  No update state — run 'aos check-update' first"
    fi
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
    --apply)
        check
        result=$?
        if [[ $result -eq 2 ]]; then
            apply
        elif [[ $result -eq 0 ]]; then
            log "Already up to date"
        fi
        ;;
    --status)
        status
        ;;
    *)
        check
        # No notification — auto-update at 4am handles it.
        # Only log to state file for dashboard visibility.
        ;;
esac
