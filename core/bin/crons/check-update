#!/usr/bin/env bash
# check-update — release-based update system for AOS
#
# Usage:
#   check-update              — check if update available
#   check-update --apply      — check and auto-apply if available
#   check-update --continue   — phase 2: post-activation deploy (called via exec)
#   check-update --status     — print current vs remote version
#
# Architecture:
#   Uses release-manager for immutable versioned releases.
#   ~/project/aos/ is the single git clone. ~/aos is a symlink to a release.
#
#   Phase 1 (--apply): create release + activate (symlink switch)
#   Phase 2 (--continue): runs from the NEW release. Reconcile, migrate,
#   rebuild venvs, restart services, health check.
#
# Called by:
#   - Scheduler (crons.yaml) every 2 hours
#   - User via `aos check-update` / `aos update`
#   - Dashboard update button

set +e

AOS_DIR="$HOME/aos"
DEV_REPO="$HOME/project/aos"
STATE_FILE="$HOME/.aos/data/update-state.json"
HANDOFF_FILE="$HOME/.aos/data/update-handoff.json"
HASH_FILE="$HOME/.aos/data/deployed-hash"
RELEASE_MGR="$AOS_DIR/core/bin/internal/release-manager"
LOG_PREFIX="[$(date '+%Y-%m-%d %H:%M:%S')]"

mkdir -p "$(dirname "$STATE_FILE")"

log() { echo "$LOG_PREFIX $*"; }

# ── Telegram notification (best-effort) ───────────���──────────────────────────

notify() {
    local msg="$1"
    local bot_token chat_id
    bot_token=$("$AOS_DIR/core/bin/cli/agent-secret" get TELEGRAM_BOT_TOKEN 2>/dev/null) || return 0
    chat_id=$("$AOS_DIR/core/bin/cli/agent-secret" get TELEGRAM_CHAT_ID 2>/dev/null) || return 0
    [[ -z "$bot_token" || -z "$chat_id" ]] && return 0

    curl -s --max-time 10 -X POST "https://api.telegram.org/bot${bot_token}/sendMessage" \
        -H "Content-Type: application/json" \
        -d "{\"chat_id\": ${chat_id}, \"text\": \"${msg}\", \"parse_mode\": \"HTML\"}" \
        > /dev/null 2>&1 || true
}

# ── Check for updates ───────────────��────────────────────────────────────────

check() {
    if [ ! -d "$DEV_REPO/.git" ]; then
        log "ERROR: Dev repo not found at $DEV_REPO"
        return 1
    fi

    cd "$DEV_REPO" || { log "ERROR: Cannot cd to dev repo"; return 1; }

    git fetch origin main --quiet 2>/dev/null || {
        log "WARN: git fetch failed (network?)"
        return 1
    }

    local remote_hash
    remote_hash=$(git rev-parse origin/main 2>/dev/null)
    local deployed_hash
    deployed_hash=$(cat "$HASH_FILE" 2>/dev/null || echo "none")

    if [[ "$remote_hash" == "$deployed_hash" ]]; then
        log "Up to date"
        python3 -c "
import json, datetime
state = {
    'last_check': datetime.datetime.now().isoformat(),
    'status': 'up_to_date',
    'deployed': '$deployed_hash',
    'remote': '$remote_hash',
}
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
"
        return 0
    fi

    local behind
    behind=$(git rev-list --count "$deployed_hash..$remote_hash" 2>/dev/null || echo "?")
    local changes
    changes=$(git log --oneline "$deployed_hash..$remote_hash" 2>/dev/null | head -5)

    log "Update available: $behind new commit(s)"

    python3 -c "
import json, datetime
state = {
    'last_check': datetime.datetime.now().isoformat(),
    'status': 'update_available',
    'deployed': '$deployed_hash',
    'remote': '$remote_hash',
    'behind': '$behind',
    'changes': '''$changes'''.strip().split('\n'),
}
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
"

    return 0
}

# ── Phase 1: Create release and activate ─────��────────────────────────────

apply() {
    log "Phase 1: creating release..."

    local old_version
    old_version=$(cat "$AOS_DIR/VERSION" 2>/dev/null || echo "unknown")

    # Create a new release from origin/main
    local release_name
    release_name=$(bash "$RELEASE_MGR" create)
    local create_status=$?

    if [[ $create_status -ne 0 ]]; then
        log "ERROR: Failed to create release"
        notify "⚠️ System update failed (release creation). Will retry next cycle."
        return 1
    fi

    # If no new release was needed (already deployed), we're done
    if [[ -z "$release_name" ]] || echo "$release_name" | grep -q "Already at"; then
        log "Already up to date"
        return 0
    fi

    # Extract just the release name (last line of output)
    release_name=$(echo "$release_name" | tail -1)

    log "Activating release $release_name..."

    # Activate — this switches the ~/aos symlink and runs validation
    bash "$RELEASE_MGR" activate "$release_name"
    local activate_status=$?

    if [[ $activate_status -ne 0 ]]; then
        log "ERROR: Activation failed — validation rejected the release"
        notify "⚠️ Release $release_name failed validation. Not activated."
        return 1
    fi

    local new_version
    new_version=$(cat "$AOS_DIR/VERSION" 2>/dev/null || echo "unknown")

    # Write handoff for phase 2
    python3 -c "
import json, datetime
handoff = {
    'triggered_at': datetime.datetime.now().isoformat(),
    'old_version': '$old_version',
    'new_version': '$new_version',
    'release': '$release_name',
}
with open('$HANDOFF_FILE', 'w') as f:
    json.dump(handoff, f, indent=2)
"

    log "Release activated ($old_version → $new_version). Handing off to new script..."

    # Replace this process with the NEW release's check-update for phase 2
    exec "$AOS_DIR/core/bin/crons/check-update" --continue
}

# ── Phase 2: Deploy (runs from NEW release on disk) ──────────────────────

deploy() {
    cd "$AOS_DIR" || exit 1

    if [[ ! -f "$HANDOFF_FILE" ]]; then
        log "No handoff file — nothing to deploy"
        return 0
    fi

    local old_version new_version release_name
    old_version=$(python3 -c "import json; print(json.load(open('$HANDOFF_FILE'))['old_version'])" 2>/dev/null)
    new_version=$(python3 -c "import json; print(json.load(open('$HANDOFF_FILE'))['new_version'])" 2>/dev/null)
    release_name=$(python3 -c "import json; print(json.load(open('$HANDOFF_FILE'))['release'])" 2>/dev/null)

    # Delete handoff BEFORE destructive work — idempotency guard.
    rm -f "$HANDOFF_FILE"

    log "Phase 2: deploying $release_name ($old_version → $new_version)"

    # Always run reconcile
    log "Running reconcile..."
    "$AOS_DIR/core/bin/internal/aos-python" "$AOS_DIR/core/infra/reconcile/runner.py" run \
        2>>"$HOME/.aos/logs/reconcile-stderr.log" || true

    # Skip the rest if version didn't change (reconcile-only update)
    if [[ "$old_version" == "$new_version" ]]; then
        log "No version change ($old_version) — reconcile only"
        return 0
    fi

    # Run migrations
    log "Running migrations..."
    "$AOS_DIR/core/bin/internal/aos-python" "$AOS_DIR/core/infra/migrations/runner.py" migrate 2>/dev/null || {
        log "ERROR: migrations failed — rolling back"
        bash "$RELEASE_MGR" rollback
        notify "⚠️ Update to $new_version: migrations failed. Rolled back."
        return 1
    }

    # Sync
    log "Syncing..."
    for cmd in sync-skills sync-agents sync-rules sync-mcp; do
        bash "$AOS_DIR/core/bin/cli/aos" "$cmd" 2>/dev/null || true
    done

    # Detect changed services by comparing dev repo history
    local old_hash new_hash changed_services
    old_hash=$(cat "$HASH_FILE" 2>/dev/null || echo "")
    new_hash=$(cd "$DEV_REPO" && git rev-parse origin/main 2>/dev/null)
    if [[ -n "$old_hash" && -n "$new_hash" ]]; then
        changed_services=$(cd "$DEV_REPO" && git diff --name-only "$old_hash..$new_hash" 2>/dev/null \
            | grep -E "core/services/[^/]+/(pyproject\.toml|[^/]+\.py)" \
            | sed 's|core/services/\([^/]*\)/.*|\1|' \
            | sort -u || true)
    fi

    if [[ -n "${changed_services:-}" ]]; then
        log "Code/deps changed in: $changed_services"
        for svc in $changed_services; do
            if [[ -d "$HOME/.aos/services/$svc" ]]; then
                log "Rebuilding $svc venv..."
                rm -rf "$HOME/.aos/services/$svc/.venv"
                bash "$AOS_DIR/core/bin/cli/aos" deploy "$svc" 2>/dev/null || true
            fi
        done
    fi

    # Auto-discover which services need restart from LaunchAgents
    local uid
    uid=$(id -u)
    local restarted_services=()

    for la_plist in "$HOME/Library/LaunchAgents/com.aos."*.plist; do
        [[ -f "$la_plist" ]] || continue
        local la_name svc_name
        la_name=$(basename "$la_plist" .plist)
        svc_name="${la_name#com.aos.}"

        if echo "${changed_services:-}" | grep -qx "$svc_name"; then
            log "Restarting $svc_name..."
            launchctl bootout "gui/$uid/$la_name" 2>/dev/null
            launchctl bootstrap "gui/$uid" "$la_plist" 2>/dev/null
            launchctl kickstart -k "gui/$uid/$la_name" 2>/dev/null
            restarted_services+=("$la_name")
        fi
    done

    # Health check for restarted services only
    if [[ ${#restarted_services[@]} -gt 0 ]]; then
        _health_check "$uid" "$new_version" "${restarted_services[@]}"
    fi

    # Prune old releases
    bash "$RELEASE_MGR" prune 5 2>/dev/null || true

    # Release notes + state update + notification
    local release_notes
    release_notes=$(_extract_release_notes "$new_version")

    python3 -c "
import json, datetime
state = {
    'last_check': datetime.datetime.now().isoformat(),
    'last_update': datetime.datetime.now().isoformat(),
    'status': 'up_to_date',
    'version': '$new_version',
    'release': '$release_name',
    'deployed': '$new_hash',
    'remote': '$new_hash',
}
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
"

    log "Update complete: $new_version ($release_name)"

    local note_text
    note_text="━━━━━━━━━━━━━━━━━━
AOS $new_version
━━━━━━━━━━━━━━━━━━

$release_notes

Already applied. No action needed."
    notify "$note_text"
}

# ── Health check ─���────────────────────────────────────��──────────────────────

_health_check() {
    local uid="$1" new_version="$2"
    shift 2
    local services=("$@")

    local max_attempts=8 attempt=0 all_up=false

    while [[ $attempt -lt $max_attempts ]]; do
        sleep 2
        attempt=$((attempt + 1))
        all_up=true
        for la in "${services[@]}"; do
            if ! launchctl list 2>/dev/null | grep -q "$la"; then
                all_up=false
                break
            fi
        done
        [[ "$all_up" == true ]] && break
        [[ $attempt -lt $max_attempts ]] && log "Health check attempt $attempt/$max_attempts — waiting..."
    done

    if [[ "$all_up" == false ]]; then
        for la in "${services[@]}"; do
            if ! launchctl list 2>/dev/null | grep -q "$la"; then
                local svc_name="${la#com.aos.}"
                log "WARN: $svc_name not running — attempting restart"
                launchctl bootout "gui/$uid/$la" 2>/dev/null
                launchctl bootstrap "gui/$uid" "$HOME/Library/LaunchAgents/${la}.plist" 2>/dev/null
                launchctl kickstart -k "gui/$uid/$la" 2>/dev/null
            fi
        done
        notify "⚠️ Update to $new_version applied but some services needed extra restart. Check 'aos status'."
    fi
}

# ── Release notes extraction ────────────���───────────────────────────────────

_extract_release_notes() {
    local version="$1"
    python3 -c "
from pathlib import Path
import re

cl = Path('$AOS_DIR/CHANGELOG.md')
if not cl.exists():
    print('System updated.')
    raise SystemExit()

content = cl.read_text()
pattern = r'## ${version}\b.*?\n(.*?)(?=\n## v|\Z)'
match = re.search(pattern, content, re.DOTALL)
if not match:
    print('System updated.')
    raise SystemExit()

notes = match.group(1).strip()
lines = [l.strip() for l in notes.split('\n') if l.strip()]

summary = ''
changes = {'Added': [], 'Changed': [], 'Fixed': [], 'Removed': []}
verb_map = {'Added': 'Added', 'Changed': 'Changed', 'Fixed': 'Fixed', 'Removed': 'Removed',
            'Rewrote': 'Changed', 'Expanded': 'Changed', 'Moved': 'Changed'}
other = []

for line in lines:
    if line.startswith('Summary:'):
        summary = line.replace('Summary:', '').strip()
    elif line.startswith('- '):
        text = line[2:]
        matched = False
        for verb, cat in verb_map.items():
            if text.startswith(verb + ' '):
                changes[cat].append(text[len(verb)+1:])
                matched = True
                break
        if not matched:
            other.append(text)
    elif ':' in line and line.split(':')[0] in changes:
        cat = line.split(':')[0]
        rest = ':'.join(line.split(':')[1:]).strip().lstrip('- ')
        changes[cat].append(rest)
    elif not line.startswith('#') and not summary:
        summary = line
    elif not line.startswith('#'):
        other.append(line)

if summary:
    print(summary)
    print()

icons = {'Added': '✦', 'Changed': '↻', 'Fixed': '✓', 'Removed': '✕'}
for cat in ['Added', 'Changed', 'Fixed', 'Removed']:
    items = changes[cat]
    if not items:
        continue
    icon = icons[cat]
    for item in items[:8]:
        print(f'{icon} {item}')
    if len(items) > 8:
        print(f'  ... and {len(items)-8} more')

if other:
    for line in other[:3]:
        print(f'  {line}')
" 2>/dev/null
}

# ── Status ────────���─────────────────────────────────���────────────────────────

status() {
    if [[ -f "$STATE_FILE" ]]; then
        python3 -c "
import json
with open('$STATE_FILE') as f:
    s = json.load(f)
print(f\"  Status:     {s.get('status', 'unknown')}\")
print(f\"  Release:    {s.get('release', 'unknown')}\")
print(f\"  Last check: {s.get('last_check', 'never')}\")
behind = s.get('behind', 0)
if behind and str(behind) not in ('0', ''):
    print(f\"  Behind:     {behind} commit(s)\")
    for c in s.get('changes', []):
        print(f\"    {c}\")
if s.get('last_update'):
    print(f\"  Last update: {s['last_update']}\")
"
    else
        echo "  No update state — run 'aos check-update' first"
    fi
}

# ── Main ─────────────────────��───────────────────────���───────────────────────

case "${1:-}" in
    --apply)
        check
        # check writes state file; read it to decide
        update_status=$(python3 -c "
import json
try:
    s = json.load(open('$STATE_FILE'))
    print(s.get('status', 'unknown'))
except: print('unknown')
" 2>/dev/null)
        if [[ "$update_status" == "update_available" ]]; then
            apply
        else
            log "Already up to date"
        fi
        ;;
    --continue)
        deploy
        ;;
    --status)
        status
        ;;
    *)
        check
        ;;
esac
