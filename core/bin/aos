#!/usr/bin/env bash
# AOS CLI — entry point for system management
#
# Usage:
#   aos start           Open editor with Claude Code (first run = onboarding)
#   aos migrate         Run pending migrations
#   aos status          Show migration version + pending
#   aos discover        Scan machine for existing setup
#   aos update          Pull latest + run migrations
#   aos version         Show current version
#   aos self-test       Validate system health
#   aos deploy [svc]    Deploy service venv (all or specific)

set -euo pipefail

AOS_DIR="$HOME/aos"
RUNNER="$AOS_DIR/core/migrations/runner.py"

case "${1:-help}" in
    migrate)
        python3 "$RUNNER" migrate
        ;;

    status)
        python3 "$RUNNER" status
        ;;

    discover)
        python3 "$RUNNER" discover
        ;;

    update)
        # Full update: pull + migrate + sync
        bash "$AOS_DIR/core/bin/check-update" --apply
        # Check if any reported issues were fixed in this update
        bash "$AOS_DIR/core/bin/check-fixed-issues" 2>/dev/null || true
        ;;

    check-update)
        bash "$AOS_DIR/core/bin/check-update" "${2:---status}"
        ;;

    sync-skills)
        # Sync skills by tier. Default skills are always installed.
        # Developer skills only if --all flag or user has opted in.
        SOURCE="$AOS_DIR/.claude/skills"
        TARGET="$HOME/.claude/skills"
        mkdir -p "$TARGET"

        # Default skills — installed for everyone
        DEFAULT_SKILLS="recall work review step-by-step obsidian-cli extract telegram-admin bridge-ops marketing diagram session-analysis frontend-design architect skill-creator skill-scanner"

        # Developer skills — opt-in via 'aos sync-skills --all' or onboarding
        DEV_SKILLS="systematic-debugging verification-before-completion requesting-code-review receiving-code-review executing-plans writing-plans dispatching-parallel-agents writing-skills autonomous-execution"

        # Deprecated — never install
        DEPRECATED="instagram youtube"

        # Determine which set to install
        skills_to_sync="$DEFAULT_SKILLS"
        if [ "${2:-}" = "--all" ]; then
            skills_to_sync="$DEFAULT_SKILLS $DEV_SKILLS"
            echo "  Installing all skills (default + developer)"
        elif [ -f "$HOME/.aos/config/developer-mode" ]; then
            skills_to_sync="$DEFAULT_SKILLS $DEV_SKILLS"
            echo "  Developer mode — installing all skills"
        fi

        synced=0
        for name in $skills_to_sync; do
            src="$SOURCE/$name/"
            link="$TARGET/$name"
            [ -d "$src" ] || continue
            if [ -L "$link" ] && [ "$(readlink "$link")" = "$src" ]; then
                continue  # already correct
            fi
            # Remove stale link or back up existing
            if [ -e "$link" ] || [ -L "$link" ]; then
                if [ -L "$link" ]; then
                    rm "$link"
                elif [ ! -e "$TARGET/${name}.pre-aos" ]; then
                    mv "$link" "$TARGET/${name}.pre-aos"
                    echo "  Backed up $name → ${name}.pre-aos"
                else
                    rm -rf "$link"
                fi
            fi
            ln -s "$src" "$link"
            echo "  ✓ Linked $name"
            ((synced++))
        done

        # Remove deprecated skills if they exist
        for name in $DEPRECATED; do
            link="$TARGET/$name"
            if [ -L "$link" ]; then
                rm "$link"
                echo "  ✗ Removed deprecated: $name"
            fi
        done

        if [ "$synced" -eq 0 ]; then
            echo "  ✓ All skills in sync"
        else
            echo "  ✓ Synced $synced skill(s)"
        fi
        ;;

    sync-agents)
        # Re-run agent symlinking — picks up new agents
        SOURCE="$AOS_DIR/core/agents"
        TARGET="$HOME/.claude/agents"
        mkdir -p "$TARGET"
        synced=0
        for src in "$SOURCE"/*.md; do
            [ -f "$src" ] || continue
            name=$(basename "$src")
            link="$TARGET/$name"
            if [ -L "$link" ] && [ "$(readlink "$link")" = "$src" ]; then
                continue
            fi
            if [ -e "$link" ] || [ -L "$link" ]; then
                if [ -L "$link" ]; then
                    rm "$link"
                elif [ ! -e "$TARGET/${name}.pre-aos" ]; then
                    mv "$link" "$TARGET/${name}.pre-aos"
                else
                    rm -f "$link"
                fi
            fi
            ln -s "$src" "$link"
            echo "  ✓ Linked $name"
            ((synced++))
        done
        if [ "$synced" -eq 0 ]; then
            echo "  ✓ All agents in sync"
        else
            echo "  ✓ Synced $synced agent(s)"
        fi
        ;;

    version)
        if [ -f "$HOME/.aos/.version" ]; then
            echo "AOS version: $(cat "$HOME/.aos/.version")"
        else
            echo "AOS version: 0 (not yet migrated)"
        fi
        ;;

    self-test)
        echo "=== AOS Self-Test ==="
        echo ""
        errors=0

        # Check Python
        if command -v python3 &>/dev/null; then
            echo "  ✓ Python3 available"
        else
            echo "  ✗ Python3 not found"
            ((errors++))
        fi

        # Check PyYAML
        if python3 -c "import yaml" 2>/dev/null; then
            echo "  ✓ PyYAML installed"
        else
            echo "  ✗ PyYAML not installed (pip3 install pyyaml)"
            ((errors++))
        fi

        # Check user data dir
        if [ -d "$HOME/.aos" ]; then
            echo "  ✓ User data dir exists"
        else
            echo "  ✗ User data dir missing (run: aos migrate)"
            ((errors++))
        fi

        # Check config files
        if [ -f "$AOS_DIR/config/crons.yaml" ]; then
            echo "  ✓ Config files exist"
        else
            echo "  ✗ Config files missing"
            ((errors++))
        fi

        # Check agent symlinks
        for agent in chief steward advisor; do
            link="$HOME/.claude/agents/${agent}.md"
            if [ -L "$link" ]; then
                echo "  ✓ Agent $agent symlinked"
            elif [ -f "$link" ]; then
                echo "  ~ Agent $agent exists but not symlinked"
            else
                echo "  ✗ Agent $agent not installed"
                ((errors++))
            fi
        done

        # Check skills
        for skill in recall work review step-by-step; do
            link="$HOME/.claude/skills/$skill"
            if [ -L "$link" ]; then
                echo "  ✓ Skill $skill symlinked"
            elif [ -d "$link" ]; then
                echo "  ~ Skill $skill exists but not symlinked"
            else
                echo "  ✗ Skill $skill not installed"
                ((errors++))
            fi
        done

        # Check work engine
        if python3 -c "
import sys; sys.path.insert(0, '$AOS_DIR/core/work')
from engine import _load
_load()
" 2>/dev/null; then
            echo "  ✓ Work engine loads"
        else
            echo "  ✗ Work engine failed to load"
            ((errors++))
        fi

        # Check scripts parse
        script_errors=0
        for script in "$AOS_DIR"/core/bin/*; do
            [ -f "$script" ] || continue
            basename=$(basename "$script")
            [ "$basename" = "__pycache__" ] && continue
            [ "$basename" = "aos" ] && continue

            # Check if Python script
            if head -1 "$script" | grep -q python; then
                if python3 -c "
import py_compile, sys
try:
    py_compile.compile('$script', doraise=True)
except py_compile.PyCompileError as e:
    print(f'  ✗ Script $basename: {e}')
    sys.exit(1)
" 2>/dev/null; then
                    : # ok
                else
                    ((script_errors++))
                fi
            fi
        done
        if [ "$script_errors" -eq 0 ]; then
            echo "  ✓ All Python scripts parse"
        else
            echo "  ✗ $script_errors scripts failed to parse"
            ((errors++))
        fi

        # Check events.jsonl
        if [ -f "$HOME/.aos/events.jsonl" ]; then
            echo "  ✓ Event bus exists"
        else
            echo "  ✗ Event bus missing (run: aos migrate)"
            ((errors++))
        fi

        echo ""
        if [ "$errors" -eq 0 ]; then
            echo "  ✓ All checks passed"
        else
            echo "  ✗ $errors check(s) failed"
        fi
        ;;

    start)
        # Flow: write a VS Code task that auto-runs cld → open VS Code
        # Claude Code needs the IDE terminal for interactive features (AskUserQuestion).
        EDITOR_FILE="$HOME/.aos/config/editor"
        EDITOR_CMD=""

        if [[ -f "$EDITOR_FILE" ]]; then
            EDITOR_CMD=$(cat "$EDITOR_FILE")
        else
            command -v cursor &>/dev/null && EDITOR_CMD="cursor"
            command -v code &>/dev/null && EDITOR_CMD="code"
        fi

        if [[ -z "$EDITOR_CMD" ]]; then
            echo "No editor found. Install VS Code or Cursor, then run aos start."
            echo "Or run cld directly: cld"
            exit 1
        fi

        # Write VS Code workspace settings + task that auto-runs cld on folder open
        vscode_dir="$HOME/.vscode"
        mkdir -p "$vscode_dir"

        # Set terminal to open in editor area (main panel, not bottom)
        # VS Code settings: terminal in editor area, hide bottom panel
        # Merge with existing settings if present
        python3 -c "
import json
from pathlib import Path
p = Path('$vscode_dir/settings.json')
s = json.loads(p.read_text()) if p.exists() else {}
s['terminal.integrated.defaultLocation'] = 'editor'
s['terminal.integrated.tabs.enabled'] = False
p.write_text(json.dumps(s, indent=2) + '\n')
" 2>/dev/null

        # Build the cld command — if onboarding isn't done, pass initial prompt
        cld_command="cld"
        if [[ ! -f "$HOME/.aos/config/onboarding.yaml" ]]; then
            cld_command="cld 'Start onboarding. Read ~/.claude/skills/onboard/SKILL.md and follow the protocol.'"
        fi

        cat > "$vscode_dir/tasks.json" << TASKS
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Claude Code",
      "type": "shell",
      "command": "${cld_command}",
      "runOptions": { "runOn": "folderOpen" },
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
TASKS

        echo ""
        echo "  Opening $EDITOR_CMD..."

        # Close the bottom panel after VS Code opens
        ( sleep 3 && "$EDITOR_CMD" --command "workbench.action.closePanel" 2>/dev/null ) &
        if [[ ! -f "$HOME/.aos/config/onboarding.yaml" ]]; then
            echo "  Claude Code will start automatically — Sahib will walk you through setup."
        else
            echo "  Claude Code will start automatically in the terminal."
        fi
        echo ""

        # Open editor to home directory — task auto-runs cld
        exec "$EDITOR_CMD" "$HOME"
        ;;

    deploy)
        SERVICES_SRC="$AOS_DIR/core/services"
        SERVICES_DST="$HOME/.aos/services"
        svc="${2:-}"

        # Find best python for venvs (3.11+, prefer homebrew)
        _find_python() {
            for p in /opt/homebrew/bin/python3.13 /opt/homebrew/bin/python3 "$HOME/.local/bin/python3"; do
                if [[ -f "$p" ]]; then
                    local minor
                    minor=$("$p" --version 2>&1 | awk '{print $2}' | cut -d. -f2)
                    if [[ "$minor" -ge 11 ]]; then
                        echo "$p"
                        return
                    fi
                fi
            done
            echo "python3"
        }

        deploy_one() {
            local name="$1"
            local src="$SERVICES_SRC/$name"
            local dst="$SERVICES_DST/$name"

            if [ ! -f "$src/pyproject.toml" ]; then
                echo "  ✗ $name: no pyproject.toml"
                return 1
            fi

            echo "  Deploying $name..."
            mkdir -p "$dst"

            local py_bin
            py_bin=$(_find_python)

            # Always rebuild venv if python version is wrong
            if [[ -d "$dst/.venv" ]]; then
                local venv_ver
                venv_ver=$("$dst/.venv/bin/python" --version 2>&1 | awk '{print $2}' | cut -d. -f2 || echo "0")
                if [[ "$venv_ver" -lt 11 ]]; then
                    echo "    Venv has Python 3.$venv_ver — rebuilding with 3.11+"
                    rm -rf "$dst/.venv"
                fi
            fi

            if [[ ! -d "$dst/.venv" ]]; then
                echo "    Creating venv with $py_bin..."
                uv venv "$dst/.venv" --python "$py_bin" 2>&1 | tail -2
                if [[ ! -f "$dst/.venv/bin/python" ]]; then
                    echo "  ✗ $name: venv creation failed"
                    return 1
                fi
            fi

            # Extract deps from pyproject.toml
            local deps
            deps=$(python3 -c "
try:
    import tomllib
except ImportError:
    try:
        import tomli as tomllib
    except ImportError:
        import re, sys
        deps = []
        in_deps = False
        for line in open('$src/pyproject.toml'):
            s = line.strip()
            if s == 'dependencies = [': in_deps = True; continue
            if in_deps and s == ']': break
            if in_deps:
                m = re.search(r'\"(.+?)\"', line)
                if m: deps.append(m.group(1))
        print('\n'.join(deps))
        sys.exit(0)
with open('$src/pyproject.toml', 'rb') as f:
    deps = tomllib.load(f).get('project', {}).get('dependencies', [])
print('\n'.join(deps))
" 2>/dev/null)

            if [[ -z "$deps" ]]; then
                echo "  ✗ $name: could not read dependencies"
                return 1
            fi

            # Install deps — show output so failures are visible
            echo "    Installing: $(echo "$deps" | tr '\n' ' ')"
            if ! echo "$deps" | uv pip install -p "$dst/.venv/bin/python" -r - 2>&1 | tail -5; then
                echo "  ✗ $name: pip install failed"
                return 1
            fi

            # Verify critical imports work
            local verify_ok=true
            for mod in yaml; do
                if ! "$dst/.venv/bin/python" -c "import $mod" 2>/dev/null; then
                    echo "    ✗ Missing: $mod"
                    verify_ok=false
                fi
            done

            if [[ "$verify_ok" == true ]]; then
                echo "    ✓ $name deployed (Python $("$dst/.venv/bin/python" --version 2>&1 | awk '{print $2}'))"
            else
                echo "  ✗ $name: deployed but missing dependencies — try: aos deploy $name"
                return 1
            fi
        }

        echo "=== AOS Deploy ==="
        echo ""
        if [ -n "$svc" ]; then
            deploy_one "$svc"
        else
            for src_dir in "$SERVICES_SRC"/*/; do
                name=$(basename "$src_dir")
                [ -f "$src_dir/pyproject.toml" ] && deploy_one "$name"
            done
        fi
        echo ""
        echo "  ✓ Deploy complete"
        ;;

    activate)
        # Activate a catalog agent
        shift
        bash "$AOS_DIR/core/bin/activate-agent" "$@"
        ;;

    deactivate)
        # Deactivate a catalog agent
        shift
        bash "$AOS_DIR/core/bin/activate-agent" --deactivate "$@"
        ;;

    trust)
        # Trust review and management
        shift
        python3 "$AOS_DIR/core/bin/trust-review" "$@"
        ;;

    trust-log)
        # Log a trust action
        shift
        python3 "$AOS_DIR/core/bin/trust-log" "$@"
        ;;

    feedback)
        shift
        bash "$AOS_DIR/core/bin/feedback" "$@"
        ;;

    telemetry)
        shift
        bash "$AOS_DIR/core/bin/telemetry" "$@"
        ;;

    sessions)
        shift
        bash "$AOS_DIR/core/bin/session-recorder" "$@"
        ;;

    rename-agent)
        # Rename the main orchestrator agent
        shift
        new_name="${1:-}"
        if [[ -z "$new_name" ]]; then
            echo "Usage: aos rename-agent <new-name>"
            echo "Example: aos rename-agent sahib"
            echo ""
            # Show current name
            current=$(python3 -c "
import yaml
from pathlib import Path
d = yaml.safe_load(Path.home().joinpath('.aos/config/operator.yaml').read_text()) or {}
print(d.get('agent_name', 'chief'))
" 2>/dev/null || echo "chief")
            echo "Current agent name: $current"
            exit 1
        fi

        # Validate: lowercase, no spaces
        if [[ "$new_name" =~ [^a-z0-9_-] ]]; then
            echo "Agent name must be lowercase letters, numbers, hyphens, or underscores."
            exit 1
        fi

        agents_dir="$HOME/.claude/agents"
        chief_source="$AOS_DIR/core/agents/chief.md"

        # Read current name
        old_name=$(python3 -c "
import yaml
from pathlib import Path
d = yaml.safe_load(Path.home().joinpath('.aos/config/operator.yaml').read_text()) or {}
print(d.get('agent_name', 'chief'))
" 2>/dev/null || echo "chief")

        # Create new symlink
        ln -sf "$chief_source" "$agents_dir/${new_name}.md"
        echo "  Created agent: $agents_dir/${new_name}.md"

        # Remove old symlink if it was a custom name (don't remove chief.md)
        if [[ "$old_name" != "chief" ]] && [[ "$old_name" != "$new_name" ]]; then
            rm -f "$agents_dir/${old_name}.md" 2>/dev/null
            echo "  Removed old: $agents_dir/${old_name}.md"
        fi

        # Update operator.yaml
        python3 -c "
import yaml
from pathlib import Path
p = Path.home() / '.aos/config/operator.yaml'
d = yaml.safe_load(p.read_text()) or {}
d['agent_name'] = '$new_name'
p.write_text(yaml.dump(d, default_flow_style=False, sort_keys=False, allow_unicode=True))
" 2>/dev/null
        echo "  Updated operator.yaml: agent_name=$new_name"

        # Update settings.json
        python3 -c "
import json
from pathlib import Path
p = Path.home() / '.claude/settings.json'
s = json.loads(p.read_text())
s['agent'] = '$new_name'
p.write_text(json.dumps(s, indent=2) + '\n')
" 2>/dev/null
        echo "  Updated settings.json: agent=$new_name"

        echo ""
        echo "  Done! Your agent is now '$new_name'."
        echo "  Run 'cld' to start a session with $new_name."
        ;;

    help|--help|-h)
        echo "AOS — Agentic Operating System"
        echo ""
        echo "Usage: aos <command>"
        echo ""
        echo "Commands:"
        echo "  start           Open editor with Claude Code ready"
        echo "  update          Pull latest + migrate + sync"
        echo "  check-update    Check if updates are available"
        echo "  status          Show migration version + pending"
        echo "  self-test       Validate system health"
        echo "  deploy          Deploy service venvs (all or: aos deploy bridge)"
        echo "  sync-skills     Re-sync skill symlinks (--all for developer)"
        echo "  sync-agents     Re-sync agent symlinks"
        echo "  activate        Activate a catalog agent (aos activate engineer)"
        echo "  deactivate      Deactivate a catalog agent"
        echo "  trust           Review agent trust levels"
        echo "  trust-log       Log agent trust actions"
        echo "  migrate         Run pending migrations"
        echo "  feedback         Report a bug or issue (auto-files to GitHub)"
        echo "  rename-agent     Rename your main agent (aos rename-agent sahib)"
        echo "  telemetry        Anonymous usage telemetry (opt-in/out/report)"
        echo "  sessions         View recorded onboarding/setup sessions"
        echo "  discover        Scan machine for existing setup"
        echo "  version         Show current version"
        echo ""
        ;;

    *)
        echo "Unknown command: $1"
        echo "Run 'aos help' for usage"
        exit 1
        ;;
esac
