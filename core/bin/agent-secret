#!/bin/bash
# agent-secret — wrapper around macOS Keychain for agent secrets
#
# Uses the login keychain (already unlocked, never prompts).
# Secrets are stored with service prefix "aos." to avoid conflicts.
#
# Usage:
#   agent-secret get <name>        Retrieve a secret
#   agent-secret set <name>        Store a secret (prompts for value)
#   agent-secret set <name> <val>  Store a secret directly
#   agent-secret list              List all stored secret names
#   agent-secret delete <name>     Remove a secret

set -e

ACCOUNT="aos"
SERVICE_PREFIX="aos."

usage() {
  echo "Usage: agent-secret <command> [args]"
  echo ""
  echo "Commands:"
  echo "  get <name>         Retrieve a secret"
  echo "  set <name> [value] Store a secret (prompts if no value given)"
  echo "  list               List all stored secret names"
  echo "  delete <name>      Remove a secret"
  exit 1
}

# Migrate from agent.keychain to login keychain (one-time)
_migrate() {
  if security list-keychains 2>/dev/null | grep -q "agent.keychain"; then
    # Check if agent.keychain has any secrets
    local secrets
    secrets=$(security dump-keychain agent.keychain 2>/dev/null | grep '"svce"' | sed 's/.*="//;s/"//' | sort -u)
    if [[ -n "$secrets" ]]; then
      while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        # Read from old keychain
        local val
        val=$(security find-generic-password -a "agent" -s "$name" -w agent.keychain 2>/dev/null) || continue
        # Write to login keychain with new prefix
        security delete-generic-password -a "$ACCOUNT" -s "${SERVICE_PREFIX}${name}" 2>/dev/null || true
        security add-generic-password -a "$ACCOUNT" -s "${SERVICE_PREFIX}${name}" -w "$val" 2>/dev/null || true
      done <<< "$secrets"
    fi
  fi
}

case "${1:-}" in
  get)
    [ -z "${2:-}" ] && usage
    # Try login keychain with prefix first, fall back to old agent.keychain
    security find-generic-password -a "$ACCOUNT" -s "${SERVICE_PREFIX}${2}" -w 2>/dev/null || \
    security find-generic-password -a "agent" -s "$2" -w agent.keychain 2>/dev/null || {
      echo "Error: secret '$2' not found" >&2
      exit 1
    }
    ;;

  set)
    [ -z "${2:-}" ] && usage
    VALUE="${3:-}"
    if [ -z "$VALUE" ]; then
      read -rsp "Enter value for '$2': " VALUE
      echo ""
    fi
    # Delete existing if present
    security delete-generic-password -a "$ACCOUNT" -s "${SERVICE_PREFIX}${2}" 2>/dev/null || true
    # Store in login keychain (no keychain specified = default/login)
    security add-generic-password -a "$ACCOUNT" -s "${SERVICE_PREFIX}${2}" -w "$VALUE"
    echo "Stored: $2"
    ;;

  list)
    # List from login keychain
    security dump-keychain 2>/dev/null | grep "\"svce\"" | grep "$SERVICE_PREFIX" | \
      sed "s/.*=\"${SERVICE_PREFIX}//;s/\"//" | sort -u
    # Also show any in old agent.keychain
    if security list-keychains 2>/dev/null | grep -q "agent.keychain"; then
      security dump-keychain agent.keychain 2>/dev/null | grep "\"svce\"" | \
        sed 's/.*="//;s/"//' | sort -u
    fi
    ;;

  delete)
    [ -z "${2:-}" ] && usage
    security delete-generic-password -a "$ACCOUNT" -s "${SERVICE_PREFIX}${2}" 2>/dev/null && \
      echo "Deleted: $2" || \
      echo "Error: secret '$2' not found" >&2
    ;;

  migrate)
    _migrate
    echo "Migrated secrets from agent.keychain to login keychain"
    ;;

  *)
    usage
    ;;
esac
