#!/bin/bash
# agent-secret — wrapper around macOS Keychain for agent secrets
# Usage:
#   agent-secret get <name>        Retrieve a secret
#   agent-secret set <name>        Store a secret (prompts for value)
#   agent-secret set <name> <val>  Store a secret directly
#   agent-secret list              List all stored secret names
#   agent-secret delete <name>     Remove a secret

set -e

KEYCHAIN="agent.keychain"
ACCOUNT="agent"

usage() {
  echo "Usage: agent-secret <command> [args]"
  echo ""
  echo "Commands:"
  echo "  get <name>         Retrieve a secret"
  echo "  set <name> [value] Store a secret (prompts if no value given)"
  echo "  list               List all stored secret names"
  echo "  delete <name>      Remove a secret"
  exit 1
}

check_keychain() {
  if ! security list-keychains | grep -q "$KEYCHAIN"; then
    echo "Error: $KEYCHAIN not found. Run Phase 0 setup first."
    exit 1
  fi
}

case "${1:-}" in
  get)
    [ -z "${2:-}" ] && usage
    check_keychain
    security find-generic-password -a "$ACCOUNT" -s "$2" -w "$KEYCHAIN" 2>/dev/null || {
      echo "Error: secret '$2' not found" >&2
      exit 1
    }
    ;;

  set)
    [ -z "${2:-}" ] && usage
    check_keychain
    VALUE="${3:-}"
    if [ -z "$VALUE" ]; then
      read -rsp "Enter value for '$2': " VALUE
      echo ""
    fi
    # Delete existing if present (ignore errors)
    security delete-generic-password -a "$ACCOUNT" -s "$2" "$KEYCHAIN" 2>/dev/null || true
    security add-generic-password -a "$ACCOUNT" -s "$2" -w "$VALUE" "$KEYCHAIN"
    echo "Stored: $2"
    ;;

  list)
    check_keychain
    security dump-keychain "$KEYCHAIN" 2>/dev/null | grep "\"svce\"" | sed 's/.*="//;s/"//' | sort -u
    ;;

  delete)
    [ -z "${2:-}" ] && usage
    check_keychain
    security delete-generic-password -a "$ACCOUNT" -s "$2" "$KEYCHAIN" 2>/dev/null && \
      echo "Deleted: $2" || \
      echo "Error: secret '$2' not found" >&2
    ;;

  *)
    usage
    ;;
esac
