#!/bin/bash
# onboard-project — Set up Telegram infrastructure for a new AOS project
#
# Usage: onboard-project <project-name>
#
# This script:
# 1. Prompts for manual steps (create bot, group, enable forum, add admin)
# 2. Stores bot token in Keychain
# 3. Creates forum topics for each agent
# 4. Sets bot commands and description
# 5. Registers in config/projects.yaml
# 6. Reloads bridge routes via SIGHUP

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="$(dirname "$SCRIPT_DIR")"
SECRET="$SCRIPT_DIR/agent-secret"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}→${NC} $1"; }
ok()    { echo -e "${GREEN}✓${NC} $1"; }
warn()  { echo -e "${YELLOW}⚠${NC} $1"; }
err()   { echo -e "${RED}✗${NC} $1"; exit 1; }
ask()   { echo -e "${YELLOW}?${NC} $1"; }

# ── Validate args ──────────────────────────────────────────
PROJECT="$1"
if [ -z "$PROJECT" ]; then
    echo "Usage: onboard-project <project-name>"
    echo ""
    echo "Example: onboard-project nuchay"
    exit 1
fi

PROJECT_DIR="$HOME/$PROJECT"
TOKEN_KEY="TELEGRAM_BOT_TOKEN_$(echo "$PROJECT" | tr '[:lower:]' '[:upper:]')"
CHAT_ID_KEY="TELEGRAM_CHAT_ID_$(echo "$PROJECT" | tr '[:lower:]' '[:upper:]')"

echo ""
echo "═══════════════════════════════════════════════"
echo "  AOS Project Onboarding: $PROJECT"
echo "═══════════════════════════════════════════════"
echo ""

# ── Step 1: Create bot via BotFather (manual) ──────────────
info "Step 1: Create a Telegram bot"
echo ""
echo "  Open Telegram → @BotFather → /newbot"
echo "  Bot name:     $PROJECT (or whatever you prefer)"
echo "  Bot username:  ${PROJECT}_bot (must end in 'bot')"
echo ""
ask "Paste the bot token here:"
read -r BOT_TOKEN

if [ -z "$BOT_TOKEN" ]; then
    err "No token provided"
fi

# Store token
"$SECRET" set "$TOKEN_KEY" "$BOT_TOKEN"
ok "Token stored as $TOKEN_KEY in Keychain"

# Get operator chat ID (reuse system chat ID)
SYSTEM_CHAT_ID=$("$SECRET" get TELEGRAM_CHAT_ID 2>/dev/null)
if [ -n "$SYSTEM_CHAT_ID" ]; then
    "$SECRET" set "$CHAT_ID_KEY" "$SYSTEM_CHAT_ID"
    ok "Chat ID stored as $CHAT_ID_KEY (same as system: $SYSTEM_CHAT_ID)"
else
    ask "Enter the operator's Telegram chat ID:"
    read -r CHAT_ID
    "$SECRET" set "$CHAT_ID_KEY" "$CHAT_ID"
    SYSTEM_CHAT_ID="$CHAT_ID"
fi

# ── Step 2: Create supergroup + enable forum (manual) ──────
echo ""
info "Step 2: Create a forum group"
echo ""
echo "  In Telegram:"
echo "  1. Create a new group (hamburger menu → New Group)"
echo "  2. Name it: $PROJECT"
echo "  3. Add @$(echo "$PROJECT")_bot as a member"
echo "  4. Open group settings → Topics → Enable"
echo "  5. Promote the bot to admin with 'Manage Topics' permission"
echo ""
ask "Paste the forum group ID here (starts with -, e.g. -1001234567890):"
read -r GROUP_ID

if [ -z "$GROUP_ID" ]; then
    err "No group ID provided"
fi

echo ""
ok "Group ID: $GROUP_ID"

# ── Step 3: Create forum topics (automated via Bot API) ────
echo ""
info "Step 3: Creating forum topics..."

API="https://api.telegram.org/bot${BOT_TOKEN}"

# Create a General topic for the project
create_topic() {
    local name="$1"
    local color="${2:-7322096}"  # default: blue
    local result
    result=$(curl -s -X POST "$API/createForumTopic" \
        -d "chat_id=$GROUP_ID" \
        -d "name=$name" \
        -d "icon_color=$color")

    local topic_id
    topic_id=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('result',{}).get('message_thread_id',''))" 2>/dev/null)

    if [ -n "$topic_id" ] && [ "$topic_id" != "None" ]; then
        ok "Created topic '$name' (thread_id: $topic_id)"
        echo "$topic_id"
    else
        warn "Failed to create topic '$name': $result"
        echo ""
    fi
}

# Create topics for project agents
MAIN_TOPIC_ID=""

# Check if project has agents defined
AGENTS_DIR="$PROJECT_DIR/.claude/agents"
if [ -d "$AGENTS_DIR" ]; then
    info "Found agents in $AGENTS_DIR:"
    for agent_file in "$AGENTS_DIR"/*.md; do
        [ -f "$agent_file" ] || continue
        agent_name=$(basename "$agent_file" .md)
        echo "  - $agent_name"
    done
    echo ""

    # Create a topic for each agent
    for agent_file in "$AGENTS_DIR"/*.md; do
        [ -f "$agent_file" ] || continue
        agent_name=$(basename "$agent_file" .md)
        topic_id=$(create_topic "$agent_name")
        if [ -n "$topic_id" ] && [ -z "$MAIN_TOPIC_ID" ]; then
            MAIN_TOPIC_ID="$topic_id"
        fi
    done
else
    info "No agents found at $AGENTS_DIR — creating default topic"
    MAIN_TOPIC_ID=$(create_topic "$PROJECT")
fi

# If no topics were created, use the project name
if [ -z "$MAIN_TOPIC_ID" ]; then
    warn "No topics created. You'll need to set the topic ID manually in projects.yaml"
    MAIN_TOPIC_ID="null"
fi

# ── Step 4: Set bot commands and description ───────────────
echo ""
info "Step 4: Configuring bot..."

# Set commands
curl -s -X POST "$API/setMyCommands" \
    -H "Content-Type: application/json" \
    -d '{"commands":[
        {"command":"new","description":"Start fresh session"},
        {"command":"status","description":"Check system status"},
        {"command":"tasks","description":"View tasks"},
        {"command":"help","description":"Show available commands"}
    ]}' > /dev/null

ok "Bot commands set"

# Set description
curl -s -X POST "$API/setMyDescription" \
    -d "description=AOS agent for the $PROJECT project. Send a message to get started." > /dev/null

ok "Bot description set"

# ── Step 5: Register in projects.yaml ──────────────────────
echo ""
info "Step 5: Registering in config/projects.yaml..."

# Add project entry using Python (safer YAML handling)
python3 << PYEOF
import yaml
from pathlib import Path

config_path = Path("$WORKSPACE/config/projects.yaml")
with open(config_path) as f:
    config = yaml.safe_load(f) or {}

projects = config.setdefault("projects", {})

if "$PROJECT" in projects:
    print("  Project already exists in projects.yaml — updating")

projects["$PROJECT"] = {
    "path": "~/$PROJECT",
    "description": "$PROJECT project workspace",
    "telegram": {
        "bot_token_key": "$TOKEN_KEY",
        "chat_id_key": "$CHAT_ID_KEY",
        "forum_group_id": int("$GROUP_ID"),
        "forum_topic_id": int("$MAIN_TOPIC_ID") if "$MAIN_TOPIC_ID" != "null" else None,
    },
    "agents": "auto",
    "status": "active",
}

with open(config_path, "w") as f:
    yaml.dump(config, f, default_flow_style=False, allow_unicode=True, sort_keys=False)

print("  ✓ projects.yaml updated")
PYEOF

# ── Step 6: Reload bridge routes ───────────────────────────
echo ""
info "Step 6: Reloading bridge routes..."

BRIDGE_PID=$(pgrep -f 'bridge/main.py' 2>/dev/null | head -1)
if [ -n "$BRIDGE_PID" ]; then
    kill -HUP "$BRIDGE_PID"
    ok "Sent SIGHUP to bridge (PID $BRIDGE_PID) — routes reloaded"
else
    warn "Bridge not running — routes will load on next restart"
fi

# ── Summary ────────────────────────────────────────────────
echo ""
echo "═══════════════════════════════════════════════"
echo "  Onboarding Complete: $PROJECT"
echo "═══════════════════════════════════════════════"
echo ""
echo "  Bot token:     $TOKEN_KEY (in Keychain)"
echo "  Group ID:      $GROUP_ID"
echo "  Main topic ID: $MAIN_TOPIC_ID"
echo "  Project path:  $PROJECT_DIR"
echo ""
echo "  Next steps:"
echo "  1. Send a test message in the forum topic"
echo "  2. Verify the bot responds correctly"
echo "  3. Set up project CLAUDE.md and agents if not done"
echo ""
