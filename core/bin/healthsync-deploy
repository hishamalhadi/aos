#!/bin/bash
# Auto-rebuild and deploy HealthSync to iPhone every 6 days
# Keeps the free signing fresh (expires every 7 days)

set -e

LOG="$HOME/aos/logs/healthsync-deploy.log"
PROJECT="$HOME/aos/apps/health-sync"
DEVICE_ID="00008140-000949A12EA3001C"
TEAM_ID="KYT5TSBZ8B"

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >> "$LOG"; }

log "Starting HealthSync deploy..."

# Build
cd "$PROJECT"
xcodebuild -project HealthSync.xcodeproj \
  -scheme HealthSync \
  -sdk iphoneos \
  -configuration Debug \
  -destination "id=$DEVICE_ID" \
  CODE_SIGN_STYLE=Automatic \
  DEVELOPMENT_TEAM="$TEAM_ID" \
  -allowProvisioningUpdates \
  clean build >> "$LOG" 2>&1

if [ $? -ne 0 ]; then
    log "ERROR: Build failed"
    exit 1
fi
log "Build succeeded"

# Find the built app
APP_PATH=$(find "$HOME/Library/Developer/Xcode/DerivedData" -path "*/HealthSync-*/Build/Products/Debug-iphoneos/HealthSync.app" -maxdepth 5 | head -1)

if [ -z "$APP_PATH" ]; then
    log "ERROR: Could not find built app"
    exit 1
fi

# Install
xcrun devicectl device install app --device "$DEVICE_ID" "$APP_PATH" >> "$LOG" 2>&1

if [ $? -ne 0 ]; then
    log "ERROR: Install failed (device may not be connected)"
    exit 1
fi

log "HealthSync deployed successfully"
