#!/usr/bin/env bash
# aos-release вЂ” tag a version, merge to main, push
#
# Usage:
#   aos-release v0.2.1 "Fixed voice transcription on Intel Macs"
#   aos-release v0.3.0 "Morning ramble system" "Voice notes в†’ tasks" "7-day learning drip"
#
# What it does:
#   1. Verifies you're on dev branch with clean working tree
#   2. Updates VERSION file
#   3. Prepends release notes to CHANGELOG.md
#   4. Commits the release
#   5. Merges dev в†’ main (fast-forward)
#   6. Tags the release on main
#   7. Pushes main + tag to origin
#   8. Switches back to dev
#
# Users' machines auto-update at 4am from main.
# They get a Telegram notification with the release notes.

set -euo pipefail

AOS_DIR="$HOME/aos"
VERSION_FILE="$AOS_DIR/VERSION"
CHANGELOG="$AOS_DIR/CHANGELOG.md"

RED=$'\033[31m' GREEN=$'\033[32m' YELLOW=$'\033[33m'
BOLD=$'\033[1m' DIM=$'\033[2m' RESET=$'\033[0m'

die() { echo "  ${RED}$*${RESET}" >&2; exit 1; }

# в”Ђв”Ђ Validate в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

BUMP="${1:-}"
shift || true

# Support both explicit version and bump type
case "$BUMP" in
    patch)
        # Read current version and increment patch
        CURRENT=$(cat "$VERSION_FILE" 2>/dev/null || echo "v0.0.0")
        IFS='.' read -r major minor patch <<< "${CURRENT#v}"
        VERSION="v${major}.${minor}.$((patch + 1))"
        echo "  ${DIM}Patch bump: $CURRENT в†’ $VERSION${RESET}"
        ;;
    minor)
        CURRENT=$(cat "$VERSION_FILE" 2>/dev/null || echo "v0.0.0")
        IFS='.' read -r major minor patch <<< "${CURRENT#v}"
        VERSION="v${major}.$((minor + 1)).0"
        echo "  ${DIM}Minor bump: $CURRENT в†’ $VERSION${RESET}"
        ;;
    major)
        CURRENT=$(cat "$VERSION_FILE" 2>/dev/null || echo "v0.0.0")
        IFS='.' read -r major minor patch <<< "${CURRENT#v}"
        VERSION="v$((major + 1)).0.0"
        echo "  ${DIM}Major bump: $CURRENT в†’ $VERSION${RESET}"
        ;;
    v*)
        VERSION="$BUMP"
        ;;
    *)
        echo ""
        echo "  Usage: aos-release <patch|minor|major|vX.Y.Z> <note1> [note2] ..."
        echo ""
        echo "  Semver:"
        echo "    ${BOLD}patch${RESET}  вЂ” bug fixes, small tweaks (v0.2.0 в†’ v0.2.1)"
        echo "    ${BOLD}minor${RESET}  вЂ” new features, improvements (v0.2.1 в†’ v0.3.0)"
        echo "    ${BOLD}major${RESET}  вЂ” breaking changes (v0.3.0 в†’ v1.0.0)"
        echo ""
        echo "  Current: $(cat "$VERSION_FILE" 2>/dev/null || echo "no version")"
        echo ""
        exit 1
        ;;
esac

[[ "$VERSION" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]] || die "Version must be like v0.2.1"

# Collect release notes from remaining args
NOTES=("$@")
[[ ${#NOTES[@]} -eq 0 ]] && die "Provide at least one release note"

cd "$AOS_DIR"

# Must be on dev branch
BRANCH=$(git branch --show-current)
[[ "$BRANCH" != "dev" ]] && die "Must be on dev branch (currently on $BRANCH)"

# Working tree must be clean
if [[ -n "$(git status --porcelain)" ]]; then
    echo ""
    echo "  ${YELLOW}Uncommitted changes:${RESET}"
    git status --short | head -10
    echo ""
    die "Commit or stash changes before releasing"
fi

echo ""
echo "  ${BOLD}Releasing AOS $VERSION${RESET}"
echo ""

# в”Ђв”Ђ Step 1: Update VERSION file в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

echo "$VERSION" > "$VERSION_FILE"
echo "  ${DIM}Updated VERSION в†’ $VERSION${RESET}"

# в”Ђв”Ђ Step 2: Prepend to CHANGELOG.md в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

DATE=$(date +%Y-%m-%d)

# Build the new entry вЂ” flat lines, no bullets
ENTRY="## $VERSION вЂ” $DATE"$'\n'$'\n'
for note in "${NOTES[@]}"; do
    ENTRY+="$note"$'\n'
done

# Prepend after the header line
if [[ -f "$CHANGELOG" ]]; then
    # Insert after "# AOS Changelog" header
    python3 -c "
from pathlib import Path
cl = Path('$CHANGELOG')
content = cl.read_text()
header = '# AOS Changelog'
if header in content:
    parts = content.split(header, 1)
    new = parts[0] + header + '\n\n' + '''$ENTRY''' + '\n' + parts[1].lstrip()
    cl.write_text(new)
else:
    cl.write_text(header + '\n\n' + '''$ENTRY''' + '\n' + content)
"
else
    echo "# AOS Changelog" > "$CHANGELOG"
    echo "" >> "$CHANGELOG"
    echo "$ENTRY" >> "$CHANGELOG"
fi
echo "  ${DIM}Updated CHANGELOG.md${RESET}"

# в”Ђв”Ђ Step 3: Commit on dev в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

git add VERSION CHANGELOG.md
git commit -m "release: $VERSION" --quiet
echo "  ${DIM}Committed on dev${RESET}"

# в”Ђв”Ђ Step 4: Merge to main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

git checkout main --quiet
git merge dev --ff-only --quiet
echo "  ${DIM}Merged dev в†’ main${RESET}"

# в”Ђв”Ђ Step 5: Tag в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# Build tag message from notes
TAG_MSG="$VERSION"$'\n'$'\n'
for note in "${NOTES[@]}"; do
    TAG_MSG+="- $note"$'\n'
done

git tag -a "$VERSION" -m "$TAG_MSG"
echo "  ${DIM}Tagged $VERSION${RESET}"

# в”Ђв”Ђ Step 6: Push в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

git push origin main --quiet 2>&1
git push origin "$VERSION" --quiet 2>&1
echo "  ${DIM}Pushed main + tag${RESET}"

# в”Ђв”Ђ Step 7: Back to dev в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

git checkout dev --quiet
# Merge main back so dev has the version commit
git merge main --ff-only --quiet 2>/dev/null || true
git push origin dev --quiet 2>&1

echo ""
echo "  ${GREEN}${BOLD}Released AOS $VERSION${RESET}"
echo ""
for note in "${NOTES[@]}"; do
    echo "  ${DIM}- $note${RESET}"
done
echo ""
echo "  ${DIM}Users auto-update at 4am. Telegram notification on apply.${RESET}"
echo ""
