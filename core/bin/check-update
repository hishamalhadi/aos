#!/usr/bin/env bash
# check-update — checks if a new AOS version is available
#
# Usage:
#   check-update              — check and notify if update available
#   check-update --apply      — check and auto-apply if available
#   check-update --status     — just print current vs remote version
#
# Called by:
#   - Scheduler (crons.yaml) every 2 hours
#   - User via `aos check-update`
#   - Dashboard update button

set +e

AOS_DIR="$HOME/aos"
STATE_FILE="$HOME/.aos/data/update-state.json"
LOG_PREFIX="[$(date '+%Y-%m-%d %H:%M:%S')]"

mkdir -p "$(dirname "$STATE_FILE")"

log() { echo "$LOG_PREFIX $*"; }

# ── Telegram notification (best-effort) ──────────────────────────────────────

notify() {
    local msg="$1"
    local bot_token chat_id
    bot_token=$("$AOS_DIR/core/bin/agent-secret" get TELEGRAM_BOT_TOKEN 2>/dev/null) || return 0
    chat_id=$("$AOS_DIR/core/bin/agent-secret" get TELEGRAM_CHAT_ID 2>/dev/null) || return 0
    [[ -z "$bot_token" || -z "$chat_id" ]] && return 0

    curl -s --max-time 10 -X POST "https://api.telegram.org/bot${bot_token}/sendMessage" \
        -H "Content-Type: application/json" \
        -d "{\"chat_id\": ${chat_id}, \"text\": \"${msg}\", \"parse_mode\": \"HTML\"}" \
        > /dev/null 2>&1 || true
}

# ── Check for updates ────────────────────────────────────────────────────────

check() {
    cd "$AOS_DIR" || { log "ERROR: AOS dir not found"; exit 1; }

    # Ensure we have a remote
    local remote
    remote=$(git remote 2>/dev/null | head -1)
    if [[ -z "$remote" ]]; then
        log "No git remote configured — skipping update check"
        return 1
    fi

    # Fetch latest (quiet, no merge)
    git fetch "$remote" --quiet 2>/dev/null || {
        log "WARN: git fetch failed (network?)"
        return 1
    }

    local branch
    branch=$(git branch --show-current 2>/dev/null || echo "main")
    local local_hash remote_hash
    local_hash=$(git rev-parse HEAD 2>/dev/null)
    remote_hash=$(git rev-parse "$remote/$branch" 2>/dev/null)

    if [[ -z "$remote_hash" ]]; then
        log "WARN: could not resolve remote branch"
        return 1
    fi

    if [[ "$local_hash" == "$remote_hash" ]]; then
        log "Up to date"
        # Write state
        python3 -c "
import json, datetime
state = {
    'last_check': datetime.datetime.now().isoformat(),
    'status': 'up_to_date',
    'local': '$local_hash',
    'remote': '$remote_hash',
}
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
"
        return 0
    fi

    # Count new commits
    local ahead behind
    ahead=$(git rev-list --count "$remote/$branch..HEAD" 2>/dev/null || echo 0)
    behind=$(git rev-list --count "HEAD..$remote/$branch" 2>/dev/null || echo 0)

    # Get commit summaries
    local changes
    changes=$(git log --oneline "HEAD..$remote/$branch" 2>/dev/null | head -5)

    log "Update available: $behind new commit(s)"

    # Write state
    python3 -c "
import json, datetime
state = {
    'last_check': datetime.datetime.now().isoformat(),
    'status': 'update_available',
    'local': '$local_hash',
    'remote': '$remote_hash',
    'behind': $behind,
    'ahead': $ahead,
    'changes': '''$changes'''.strip().split('\n'),
}
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
"

    return 2  # 2 = update available
}

# ── Apply update ─────────────────────────────────────────────────────────────

apply() {
    log "Applying update..."

    cd "$AOS_DIR" || exit 1

    # Snapshot for rollback
    local old_hash
    old_hash=$(git rev-parse HEAD 2>/dev/null)
    local old_version
    old_version=$(cat "$AOS_DIR/VERSION" 2>/dev/null || echo "unknown")

    # Pull (main branch only, fast-forward)
    local pull_output
    pull_output=$(git pull --ff-only origin main 2>&1)
    local pull_status=$?

    if [[ $pull_status -ne 0 ]]; then
        log "ERROR: git pull failed — attempting reset"
        # Reset any dirty state and try again
        git checkout -- . 2>/dev/null
        pull_output=$(git pull --ff-only origin main 2>&1)
        pull_status=$?
        if [[ $pull_status -ne 0 ]]; then
            log "ERROR: git pull failed after reset"
            notify "⚠️ System update failed. Will retry next cycle."
            return 1
        fi
    fi

    local new_version
    new_version=$(cat "$AOS_DIR/VERSION" 2>/dev/null || echo "unknown")

    # Always run reconcile — even if version didn't change.
    # Catches drift from Homebrew updates, manual edits, etc.
    log "Running reconcile..."
    python3 "$AOS_DIR/core/reconcile/runner.py" run 2>>"$HOME/.aos/logs/reconcile-stderr.log" || true

    # Skip the rest if version didn't change
    if [[ "$old_version" == "$new_version" ]]; then
        log "No version change ($old_version)"
        return 0
    fi

    log "Updating $old_version → $new_version"

    # Run migrations
    log "Running migrations..."
    python3 "$AOS_DIR/core/migrations/runner.py" migrate 2>/dev/null || true

    # Sync skills and agents
    log "Syncing..."
    bash "$AOS_DIR/core/bin/aos" sync-skills 2>/dev/null || true
    bash "$AOS_DIR/core/bin/aos" sync-agents 2>/dev/null || true
    bash "$AOS_DIR/core/bin/aos" sync-mcp 2>/dev/null || true

    # Check if any pyproject.toml changed — rebuild affected venvs
    local changed_services
    changed_services=$(git diff --name-only "$old_hash..HEAD" 2>/dev/null | grep "core/services/.*/pyproject.toml" | sed 's|core/services/\(.*\)/pyproject.toml|\1|' || true)
    if [[ -n "$changed_services" ]]; then
        log "Dependencies changed in: $changed_services"
        for svc in $changed_services; do
            log "Rebuilding $svc venv..."
            rm -rf "$HOME/.aos/services/$svc/.venv"
            bash "$AOS_DIR/core/bin/aos" deploy "$svc" 2>/dev/null || true
        done
    fi

    # Reload services if bridge or dashboard code changed
    local reload_bridge=false reload_dashboard=false reload_listen=false
    git diff --name-only "$old_hash..HEAD" 2>/dev/null | grep -q "core/services/bridge/" && reload_bridge=true
    git diff --name-only "$old_hash..HEAD" 2>/dev/null | grep -q "core/services/dashboard/" && reload_dashboard=true
    git diff --name-only "$old_hash..HEAD" 2>/dev/null | grep -q "core/services/listen/" && reload_listen=true

    if [[ "$reload_bridge" == true ]]; then
        log "Reloading bridge..."
        launchctl unload "$HOME/Library/LaunchAgents/com.aos.bridge.plist" 2>/dev/null
        launchctl load "$HOME/Library/LaunchAgents/com.aos.bridge.plist" 2>/dev/null
    fi
    if [[ "$reload_dashboard" == true ]]; then
        log "Reloading dashboard..."
        launchctl unload "$HOME/Library/LaunchAgents/com.aos.dashboard.plist" 2>/dev/null
        launchctl load "$HOME/Library/LaunchAgents/com.aos.dashboard.plist" 2>/dev/null
    fi
    if [[ "$reload_listen" == true ]]; then
        log "Reloading listen..."
        launchctl unload "$HOME/Library/LaunchAgents/com.aos.listen.plist" 2>/dev/null
        launchctl load "$HOME/Library/LaunchAgents/com.aos.listen.plist" 2>/dev/null
    fi

    # Health check after update
    sleep 3
    local health_ok=true
    for svc in bridge dashboard listen; do
        if ! launchctl list 2>/dev/null | grep -q "com.aos.$svc"; then
            log "WARN: $svc not running after update"
            health_ok=false
        fi
    done

    if [[ "$health_ok" == false ]]; then
        log "Health check failed — rolling back to $old_hash"
        git checkout "$old_hash" 2>/dev/null
        for la in com.aos.bridge com.aos.dashboard com.aos.listen; do
            launchctl unload "$HOME/Library/LaunchAgents/${la}.plist" 2>/dev/null
            launchctl load "$HOME/Library/LaunchAgents/${la}.plist" 2>/dev/null
        done
        notify "⚠️ Update to $new_version rolled back — services were unhealthy. Developer notified."
        bash "$AOS_DIR/core/bin/feedback" --auto "Update rollback: $new_version → $old_version" "auto-update" 2>/dev/null || true
        return 1
    fi

    # Read release notes from CHANGELOG.md — flat format, no bullets
    local release_notes
    release_notes=$(python3 -c "
from pathlib import Path
import re
cl = Path('$AOS_DIR/CHANGELOG.md')
if not cl.exists():
    print('System updated.')
    exit()
content = cl.read_text()
# Find the section for this version
pattern = r'## $new_version.*?\n(.*?)(?=\n## v|\Z)'
match = re.search(pattern, content, re.DOTALL)
if match:
    notes = match.group(1).strip()
    # Take non-empty lines (flat format — each line is a change)
    lines = [l.strip() for l in notes.split('\n') if l.strip() and not l.startswith('#')]
    # Show first 6 for Telegram (keep it readable)
    for l in lines[:6]:
        # Strip leading 'Added/Changed/Fixed' prefix for cleaner display
        print('• ' + l)
    if len(lines) > 6:
        print(f'... and {len(lines) - 6} more changes')
else:
    print('System updated.')
" 2>/dev/null)

    # Update state
    local new_hash
    new_hash=$(git rev-parse HEAD 2>/dev/null)
    python3 -c "
import json, datetime
state = {
    'last_check': datetime.datetime.now().isoformat(),
    'last_update': datetime.datetime.now().isoformat(),
    'status': 'up_to_date',
    'version': '$new_version',
    'local': '$new_hash',
    'remote': '$new_hash',
}
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
"

    log "Update complete: $new_version"

    # Send clean release notification (not "aos updated to commit hash")
    local note_text="AOS $new_version"$'\n'$'\n'"$release_notes"$'\n'$'\n'"Already applied. No action needed."
    notify "$note_text"
}

# ── Status ───────────────────────────────────────────────────────────────────

status() {
    if [[ -f "$STATE_FILE" ]]; then
        python3 -c "
import json
with open('$STATE_FILE') as f:
    s = json.load(f)
print(f\"  Status:     {s.get('status', 'unknown')}\")
print(f\"  Last check: {s.get('last_check', 'never')}\")
if s.get('behind', 0) > 0:
    print(f\"  Behind:     {s['behind']} commit(s)\")
    for c in s.get('changes', []):
        print(f\"    {c}\")
if s.get('last_update'):
    print(f\"  Last update: {s['last_update']}\")
"
    else
        echo "  No update state — run 'aos check-update' first"
    fi
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
    --apply)
        check
        result=$?
        if [[ $result -eq 2 ]]; then
            apply
        elif [[ $result -eq 0 ]]; then
            log "Already up to date"
        fi
        ;;
    --status)
        status
        ;;
    *)
        check
        result=$?
        if [[ $result -eq 2 ]]; then
            notify "🔄 AOS update available — run 'aos update' to install"
        fi
        ;;
esac
