#!/bin/bash
# deploy-metrics — Chief deploy metrics from deploy-chief.log
LOG="${HOME}/aos/logs/deploy-chief.log"

if [ ! -f "$LOG" ]; then
  echo "No deploy log found at $LOG"
  exit 1
fi

# Strip ANSI codes for clean parsing
clean() { sed 's/\x1b\[[0-9;]*m//g'; }

TOTAL=$(grep -c 'Starting deploy-chief' "$LOG")
ARCHIVE_FAIL=$(grep -c 'ARCHIVE FAILED' "$LOG")
UPLOAD_FAIL=$(grep -c '^\[!\] Error uploading ipa' "$LOG")
SUCCESS=$(cat "$LOG" | clean | grep -c 'Successfully uploaded package')
FAILURES=$((TOTAL - SUCCESS))

if [ "$TOTAL" -eq 0 ]; then
  echo "No deploy attempts found."
  exit 0
fi

SUCCESS_RATE=$(awk "BEGIN {printf \"%.0f\", ($SUCCESS/$TOTAL)*100}")

# Average attempts until success: total attempts / number of successes
if [ "$SUCCESS" -gt 0 ]; then
  AVG=$(awk "BEGIN {printf \"%.1f\", $TOTAL/$SUCCESS}")
else
  AVG="n/a"
fi

# Extract failure reasons (deduplicated, counted)
REASONS=$(cat "$LOG" | clean | grep -oE '(ARCHIVE FAILED|No Accounts|No profiles for|Missing required icon|Invalid bundle\. The|Missing purpose string|Missing Info\.plist value|Error building the application)' | sort | uniq -c | sort -rn)

# Date range
FIRST=$(grep -m1 'Starting deploy-chief' "$LOG" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}')
LAST=$(grep 'Starting deploy-chief' "$LOG" | tail -1 | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}')

echo "=== Chief Deploy Metrics ==="
echo "Period: $FIRST to $LAST"
echo ""
printf "%-24s %s\n" "Total attempts:" "$TOTAL"
printf "%-24s %s\n" "Successes:" "$SUCCESS"
printf "%-24s %s\n" "Failures:" "$FAILURES"
printf "%-24s %s\n" "  Archive failures:" "$ARCHIVE_FAIL"
printf "%-24s %s\n" "  Upload failures:" "$UPLOAD_FAIL"
printf "%-24s %s%%\n" "Success rate:" "$SUCCESS_RATE"
printf "%-24s %s\n" "Avg attempts/success:" "$AVG"
echo ""
echo "--- Top Failure Reasons ---"
echo "$REASONS" | while read -r count reason; do
  [ -n "$count" ] && printf "  %3s  %s\n" "$count" "$reason"
done
