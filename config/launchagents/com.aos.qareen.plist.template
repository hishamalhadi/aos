<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aos.qareen</string>
    <key>WorkingDirectory</key>
    <string>__HOME__/aos/core</string>
    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/.aos/services/qareen/.venv/bin/python</string>
        <string>-m</string>
        <string>uvicorn</string>
        <string>qareen.main:app</string>
        <string>--host</string>
        <string>0.0.0.0</string>
        <string>--port</string>
        <string>4096</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>5</integer>
    <key>StandardOutPath</key>
    <string>__HOME__/.aos/logs/qareen.out.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.aos/logs/qareen.err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:__HOME__/.bun/bin:__HOME__/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
